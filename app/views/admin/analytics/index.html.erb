<section class="page-hero relative">
  <span class="page-kicker">Analytics</span>
  <h1 class="page-title">See platform movement at a glance.</h1>
  <p class="page-subtitle">A cleaner operations dashboard for growth, demand, and conversion signals.</p>
</section>

<section class="section-card mb-8">
  <%= form_with url: admin_analytics_path, method: :get, local: true, class: "flex flex-col gap-4 md:flex-row md:items-end md:justify-between" do |f| %>
    <div>
      <label class="mb-2 block text-sm font-semibold text-slate-700">Date range</label>
      <%= f.select :date_range, [["Last 7 days", "7"], ["Last 30 days", "30"], ["Last 90 days", "90"], ["Last 365 days", "365"]], { selected: @date_range }, { onchange: "this.form.requestSubmit();" } %>
    </div>
  <% end %>
</section>

<section class="mb-8 stat-grid">
  <div class="stat-card"><p class="stat-label">Users</p><p class="stat-value"><%= @metrics[:total_users] %></p><p class="stat-meta">+<%= @metrics[:new_users] %> in selected period</p></div>
  <div class="stat-card"><p class="stat-label">Active jobs</p><p class="stat-value"><%= @metrics[:active_jobs] %></p><p class="stat-meta"><%= @metrics[:total_jobs] %> total jobs</p></div>
  <div class="stat-card"><p class="stat-label">Applications</p><p class="stat-value"><%= @metrics[:total_applications] %></p><p class="stat-meta">+<%= @metrics[:new_applications] %> in selected period</p></div>
  <div class="stat-card"><p class="stat-label">Companies</p><p class="stat-value"><%= @metrics[:total_companies] %></p><p class="stat-meta"><%= @metrics[:pending_companies] %> pending</p></div>
</section>

<div class="grid gap-8 lg:grid-cols-2">
  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">User registrations</h2>
    <div class="mt-5 space-y-4">
      <% @user_registrations.each do |(date, role), count| %>
        <div>
          <div class="mb-2 flex items-center justify-between text-sm">
            <span class="font-semibold text-slate-700"><%= date.strftime("%m/%d") %> • <%= role.humanize %></span>
            <span class="text-slate-500"><%= count %></span>
          </div>
          <div class="h-3 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-teal-600" style="width: <%= [count.to_f / 10 * 100, 100].min %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">Application status distribution</h2>
    <div class="mt-5 space-y-4">
      <% @application_status_distribution.each do |status, count| %>
        <div>
          <div class="mb-2 flex items-center justify-between text-sm">
            <span class="font-semibold text-slate-700"><%= status.humanize %></span>
            <span class="text-slate-500"><%= count %></span>
          </div>
          <div class="h-3 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-amber-500" style="width: <%= [count.to_f / @application_status_distribution.values.max * 100, 5].max %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</div>

<section class="section-card mt-8">
  <h2 class="text-2xl font-bold text-slate-900">Top performing jobs</h2>
  <div class="mt-5 space-y-4">
    <% @top_jobs.each do |job| %>
      <div class="section-card-muted">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <div>
            <h3 class="text-lg font-bold text-slate-900">
              <%= link_to job.title, admin_job_path(job), class: "hover:text-teal-700" %>
            </h3>
            <p class="mt-1 text-sm text-slate-500"><%= job.company.name %> • <%= job.location %></p>
          </div>
          <div class="flex gap-4 text-sm text-slate-500">
            <span><%= pluralize(job.views_count, "view") %></span>
            <span><%= pluralize(job.applications_count, "application") %></span>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>
