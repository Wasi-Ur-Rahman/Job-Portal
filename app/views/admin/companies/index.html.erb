<section class="page-hero relative">
  <span class="page-kicker">Companies</span>
  <h1 class="page-title">Review company profiles with less friction.</h1>
  <p class="page-subtitle">Status-based review for pending, approved, and rejected companies in one streamlined list.</p>
</section>

<section class="mb-8 stat-grid">
  <div class="stat-card"><p class="stat-label">All companies</p><p class="stat-value"><%= Company.count %></p></div>
  <div class="stat-card"><p class="stat-label">Pending</p><p class="stat-value"><%= @pending_count %></p></div>
  <div class="stat-card"><p class="stat-label">Approved</p><p class="stat-value"><%= @approved_count %></p></div>
  <div class="stat-card"><p class="stat-label">Rejected</p><p class="stat-value"><%= @rejected_count %></p></div>
</section>

<section class="space-y-5">
  <% if @companies.any? %>
    <% @companies.each do |company| %>
      <article class="section-card">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="text-2xl font-bold text-slate-900"><%= company.name %></h2>
              <span class="badge-pill <%= company.pending? ? "badge-amber" : company.approved? ? "badge-emerald" : "badge-red" %>"><%= company.status&.humanize || "N/A" %></span>
            </div>
            <p class="mt-2 text-sm text-slate-500"><%= company.location %> • <%= company.industry %> • <%= company.size %></p>
            <p class="mt-3 text-sm text-slate-500"><%= pluralize(company.recruiters.count, "recruiter") %> • <%= pluralize(company.jobs.count, "job") %></p>
          </div>
          <div class="flex flex-wrap gap-2">
            <% if company.pending? %>
              <%= link_to "Approve", approve_admin_company_path(company), data: { turbo_method: :patch, turbo_confirm: "Approve this company?" }, class: "btn-success" %>
              <%= link_to "Reject", reject_admin_company_path(company), data: { turbo_method: :patch, turbo_confirm: "Reject this company?" }, class: "btn-danger" %>
            <% end %>
            <%= link_to "View details", admin_company_path(company), class: "btn-secondary" %>
          </div>
        </div>
      </article>
    <% end %>
    <div class="mt-8"><%= paginate @companies if respond_to?(:paginate) %></div>
  <% else %>
    <div class="ui-empty-state"><p>No companies found in this status.</p></div>
  <% end %>
</section>
