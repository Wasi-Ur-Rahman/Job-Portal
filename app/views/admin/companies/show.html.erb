<div class="px-4 py-6 sm:px-0">
  <div class="mb-6">
    <%= link_to admin_companies_path, class: "text-indigo-600 hover:text-indigo-900" do %>
      ← Back to Companies
    <% end %>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <!-- Header -->
    <div class="px-4 py-5 sm:px-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <% if @company.logo.attached? %>
            <%= image_tag @company.logo, class: "h-16 w-16 rounded-full object-cover mr-4" %>
          <% else %>
            <div class="h-16 w-16 rounded-full bg-gray-300 flex items-center justify-center mr-4">
              <span class="text-lg font-medium text-gray-700"><%= @company.name.first.upcase %></span>
            </div>
          <% end %>
          <div>
            <h1 class="text-2xl font-bold text-gray-900"><%= @company.name %></h1>
            <p class="text-sm text-gray-500"><%= @company.location %> • <%= @company.industry %></p>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium 
                       <%= case @company.status
                           when 'pending' then 'bg-yellow-100 text-yellow-800'
                           when 'approved' then 'bg-green-100 text-green-800'
                           when 'rejected' then 'bg-red-100 text-red-800'
                           end %>">
            <%= @company.status&.humanize || "N/A" %>
          </span>
          <% if @company.pending? %>
            <%= link_to "Approve Company", approve_admin_company_path(@company), data: { turbo_method: :patch, turbo_confirm: "Are you sure?" },
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700" %>
            <%= link_to "Reject Company", reject_admin_company_path(@company), data: { turbo_method: :patch, turbo_confirm: "Are you sure?" },
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Company Details -->
    <div class="border-t border-gray-200">
      <dl>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Description</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= simple_format(@company.description) %>
          </dd>
        </div>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Website</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <% if @company.website.present? %>
              <%= link_to @company.website, @company.website, target: '_blank', class: "text-indigo-600 hover:text-indigo-900" %>
            <% else %>
              Not provided
            <% end %>
          </dd>
        </div>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Company Size</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @company.size %> employees</dd>
        </div>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Registration Date</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= @company.created_at.strftime('%B %d, %Y at %I:%M %p') %>
          </dd>
        </div>
        <% if @company.approved? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Approved By</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= @company.approved_by.full_name %> on <%= @company.approved_at.strftime('%B %d, %Y') %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <!-- Recruiters Section -->
  <div class="mt-8 bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Recruiters</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">People who can manage this company</p>
    </div>
    <div class="border-t border-gray-200">
      <% if @recruiters.any? %>
        <ul class="divide-y divide-gray-200">
          <% @recruiters.each do |recruiter| %>
            <li class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-10 w-10 bg-gray-300 rounded-full flex items-center justify-center">
                    <span class="text-sm font-medium text-gray-700"><%= recruiter.first_name.first %></span>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900"><%= recruiter.full_name %></div>
                    <div class="text-sm text-gray-500"><%= recruiter.email %></div>
                  </div>
                </div>
                <div class="text-sm text-gray-500">
                  <%= recruiter.recruiter_memberships.find_by(company: @company)&.role&.humanize %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="text-center py-6">
          <p class="text-sm text-gray-500">No recruiters assigned yet</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Jobs Section -->
  <div class="mt-8 bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">
        Jobs (<%= @jobs.count %>)
      </h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Jobs posted by this company</p>
    </div>
    <div class="border-t border-gray-200">
      <% if @jobs.any? %>
        <ul class="divide-y divide-gray-200">
          <% @jobs.limit(10).each do |job| %>
            <li class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <div>
                  <div class="text-sm font-medium text-gray-900"><%= job.title %></div>
                  <div class="text-sm text-gray-500">
                    Posted by <%= job.posted_by_user.full_name %> • 
                    <%= job.created_at.strftime('%B %d, %Y') %> • 
                    <%= job.applications_count %> applications
                  </div>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                             <%= case job.status
                                 when 'draft' then 'bg-gray-100 text-gray-800'
                                 when 'published' then 'bg-green-100 text-green-800'
                                 when 'closed' then 'bg-red-100 text-red-800'
                                 end %>">
                  <%= job.status.humanize %>
                </span>
              </div>
            </li>
          <% end %>
        </ul>
        <% if @jobs.count > 10 %>
          <div class="px-4 py-3 bg-gray-50">
            <p class="text-sm text-gray-500">
              And <%= @jobs.count - 10 %> more jobs...
              <%= link_to "View all jobs", admin_jobs_path(company_id: @company.id), class: "text-indigo-600 hover:text-indigo-900" %>
            </p>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-6">
          <p class="text-sm text-gray-500">No jobs posted yet</p>
        </div>
      <% end %>
    </div>
  </div>
</div>