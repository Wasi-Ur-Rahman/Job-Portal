<section class="section-card mb-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <span class="badge-pill <%= @company.pending? ? "badge-amber" : @company.approved? ? "badge-emerald" : "badge-red" %>"><%= @company.status&.humanize || "N/A" %></span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @company.name %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @company.location %> • <%= @company.industry %></p>
    </div>
    <% if @company.pending? %>
      <div class="flex flex-wrap gap-2">
        <%= link_to "Approve company", approve_admin_company_path(@company), data: { turbo_method: :patch, turbo_confirm: "Approve this company?" }, class: "btn-success" %>
        <%= link_to "Reject company", reject_admin_company_path(@company), data: { turbo_method: :patch, turbo_confirm: "Reject this company?" }, class: "btn-danger" %>
      </div>
    <% end %>
  </div>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    <div class="section-card-muted md:col-span-2">
      <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Description</p>
      <div class="prose mt-3 max-w-none"><%= simple_format(@company.description.presence || "No description provided.") %></div>
    </div>
    <div class="section-card-muted"><p class="text-xs uppercase tracking-[0.18em] text-slate-400">Website</p><p class="mt-2 text-lg font-semibold text-slate-900"><%= @company.website.presence || "Not provided" %></p></div>
    <div class="section-card-muted"><p class="text-xs uppercase tracking-[0.18em] text-slate-400">Size</p><p class="mt-2 text-lg font-semibold text-slate-900"><%= @company.size %> employees</p></div>
  </div>
</section>
