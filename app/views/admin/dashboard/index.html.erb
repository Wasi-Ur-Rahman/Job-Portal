<section class="page-hero relative">
  <span class="page-kicker">Admin overview</span>
  <h1 class="page-title">Monitor the platform without drowning in admin clutter.</h1>
  <p class="page-subtitle">High-level platform health, pending approvals, and the newest activity in a faster operations layout.</p>
</section>

<section class="mb-8 stat-grid">
  <div class="stat-card">
    <p class="stat-label">Users</p>
    <p class="stat-value"><%= @stats[:total_users] %></p>
    <p class="stat-meta"><%= @stats[:job_seekers] %> job seekers • <%= @stats[:recruiters] %> recruiters</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Companies</p>
    <p class="stat-value"><%= @stats[:approved_companies] %></p>
    <p class="stat-meta"><%= @stats[:pending_companies] %> pending approval</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Published jobs</p>
    <p class="stat-value"><%= @stats[:published_jobs] %></p>
    <p class="stat-meta"><%= @stats[:total_jobs] %> total jobs on platform</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Recruiter requests</p>
    <p class="stat-value"><%= @stats[:pending_recruiter_requests] %></p>
    <p class="stat-meta">Membership requests waiting for review.</p>
  </div>
</section>

<div class="grid gap-8 lg:grid-cols-2">
  <section class="section-card">
    <div class="mb-5 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">Pending recruiter requests</h2>
        <p class="mt-1 text-sm text-slate-500">Applicants waiting for company access.</p>
      </div>
      <%= link_to "Review all", admin_recruiter_requests_path, class: "btn-secondary" %>
    </div>

    <% if @pending_recruiter_requests.any? %>
      <div class="space-y-4">
        <% @pending_recruiter_requests.each do |request| %>
          <div class="section-card-muted">
            <h3 class="text-lg font-bold text-slate-900"><%= request.user.full_name %></h3>
            <p class="mt-2 text-sm text-slate-500"><%= request.company.name %> • <%= request.role.humanize %></p>
            <div class="mt-4">
              <%= link_to "Open request", admin_recruiter_request_path(request), class: "btn-ghost" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="ui-empty-state"><p>No pending recruiter requests.</p></div>
    <% end %>
  </section>

  <section class="section-card">
    <div class="mb-5 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">Pending company approvals</h2>
        <p class="mt-1 text-sm text-slate-500">New companies waiting to go live.</p>
      </div>
      <%= link_to "Open companies", admin_companies_path(status: "pending"), class: "btn-secondary" %>
    </div>

    <% if @pending_companies.any? %>
      <div class="space-y-4">
        <% @pending_companies.each do |company| %>
          <div class="section-card-muted">
            <h3 class="text-lg font-bold text-slate-900"><%= company.name %></h3>
            <p class="mt-2 text-sm text-slate-500"><%= company.location %> • <%= company.industry %></p>
            <div class="mt-4">
              <%= link_to "Review company", admin_company_path(company), class: "btn-ghost" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="ui-empty-state"><p>No pending company approvals.</p></div>
    <% end %>
  </section>
</div>

<div class="mt-8 grid gap-8 lg:grid-cols-2">
  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">Recent users</h2>
    <div class="mt-5 space-y-4">
      <% @recent_users.limit(5).each do |user| %>
        <div class="section-card-muted">
          <h3 class="text-lg font-bold text-slate-900"><%= user.full_name %></h3>
          <p class="mt-2 text-sm text-slate-500"><%= user.role.humanize %> • Joined <%= user.created_at.strftime("%b %d, %Y") %></p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">Recent jobs</h2>
    <div class="mt-5 space-y-4">
      <% @recent_jobs.limit(5).each do |job| %>
        <div class="section-card-muted">
          <h3 class="text-lg font-bold text-slate-900"><%= job.title %></h3>
          <p class="mt-2 text-sm text-slate-500"><%= job.company.name %> • <%= job.status.humanize %></p>
        </div>
      <% end %>
    </div>
  </section>
</div>
