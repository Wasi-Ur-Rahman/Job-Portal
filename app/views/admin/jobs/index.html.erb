<section class="page-hero relative">
  <span class="page-kicker">Jobs</span>
  <h1 class="page-title">Inspect every published, draft, and closed role.</h1>
  <p class="page-subtitle">A denser admin view for status checks, moderation, and performance inspection.</p>
</section>

<section class="section-card mb-8">
  <%= form_with url: admin_jobs_path, method: :get, local: true, class: "flex flex-col gap-4 md:flex-row md:items-end md:justify-between" do |f| %>
    <div class="w-full md:max-w-md">
      <%= f.label :search, "Search jobs", class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.text_field :search, value: params[:search], placeholder: "Role title or company" %>
    </div>
    <%= f.submit "Search", class: "btn-primary" %>
  <% end %>
</section>

<section class="mb-8 stat-grid">
  <div class="stat-card"><p class="stat-label">Total jobs</p><p class="stat-value"><%= Job.count %></p></div>
  <div class="stat-card"><p class="stat-label">Published</p><p class="stat-value"><%= @published_count %></p></div>
  <div class="stat-card"><p class="stat-label">Drafts</p><p class="stat-value"><%= @draft_count %></p></div>
  <div class="stat-card"><p class="stat-label">Closed</p><p class="stat-value"><%= @closed_count %></p></div>
  <div class="stat-card"><p class="stat-label">Applications</p><p class="stat-value"><%= Application.count %></p></div>
</section>

<section class="ui-table-wrap">
  <% if @jobs.any? %>
    <div class="ui-table-scroll">
      <table class="ui-table">
        <thead>
          <tr>
            <th>Role</th>
            <th>Company</th>
            <th>Status</th>
            <th>Metrics</th>
            <th>Posted</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @jobs.each do |job| %>
            <tr>
              <td>
                <div class="font-semibold text-slate-900"><%= link_to job.title, admin_job_path(job), class: "hover:text-teal-700" %></div>
                <div class="text-sm text-slate-500"><%= job.location %> • <%= job.employment_type.humanize %></div>
              </td>
              <td class="text-slate-500"><%= job.company.name %><br><span class="text-xs"><%= job.posted_by_user.full_name %></span></td>
              <td><span class="badge-pill <%= job.status == "published" ? "badge-emerald" : job.status == "closed" ? "badge-red" : "badge-slate" %>"><%= job.status.humanize %></span></td>
              <td class="text-slate-500"><%= job.views_count %> views • <%= job.applications_count %> applications</td>
              <td class="text-slate-500"><%= job.created_at.strftime("%b %d, %Y") %></td>
              <td><%= link_to "Open", admin_job_path(job), class: "btn-ghost" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="px-6 pb-6 pt-4"><%= paginate @jobs if respond_to?(:paginate) %></div>
  <% else %>
    <div class="ui-empty-state m-6"><p>No jobs matched this search.</p></div>
  <% end %>
</section>
