<section class="section-card mb-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <span class="badge-pill <%= @job.status == "published" ? "badge-emerald" : @job.status == "closed" ? "badge-red" : "badge-slate" %>"><%= @job.status.humanize %></span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @job.title %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @job.company.name %> • <%= @job.location %></p>
    </div>
    <%= link_to "Delete job", admin_job_path(@job), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this job?" }, class: "btn-danger" %>
  </div>

  <div class="mt-8 stat-grid">
    <div class="stat-card"><p class="stat-label">Views</p><p class="stat-value"><%= @job.views_count %></p></div>
    <div class="stat-card"><p class="stat-label">Applications</p><p class="stat-value"><%= @job.applications_count %></p></div>
    <div class="stat-card"><p class="stat-label">Posted</p><p class="stat-value text-2xl"><%= @job.published_at&.strftime("%b %d, %Y") || "Not published" %></p></div>
    <div class="stat-card"><p class="stat-label">Expires</p><p class="stat-value text-2xl"><%= @job.expires_at&.strftime("%b %d, %Y") || "No expiration" %></p></div>
  </div>
</section>

<section class="section-card">
  <h2 class="text-2xl font-bold text-slate-900">Description</h2>
  <div class="prose mt-5 max-w-none"><%= simple_format(@job.description) %></div>

  <% if @job.skills.any? %>
    <div class="mt-6 flex flex-wrap gap-2">
      <% @job.skills.each do |skill| %>
        <span class="badge-pill badge-blue"><%= skill.name %></span>
      <% end %>
    </div>
  <% end %>
</section>
