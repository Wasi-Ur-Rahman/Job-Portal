<div class="px-4 py-6 sm:px-0">
  <div class="mb-6">
    <%= link_to admin_jobs_path, class: "inline-flex items-center text-indigo-600 hover:text-indigo-900" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to Jobs
    <% end %>
  </div>

  <!-- Job Header -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
    <div class="px-4 py-5 sm:px-6">
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <div class="flex items-center space-x-3 mb-2">
            <h1 class="text-3xl font-bold text-gray-900"><%= @job.title %></h1>
            <span class="px-3 py-1 text-sm font-medium rounded-full 
                  <%= case @job.status
                      when 'draft' then 'bg-gray-100 text-gray-800'
                      when 'published' then 'bg-green-100 text-green-800'
                      when 'closed' then 'bg-red-100 text-red-800'
                      end %>">
              <%= @job.status.humanize %>
            </span>
          </div>
          <div class="flex items-center space-x-4 text-sm text-gray-500">
            <span class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
              <%= @job.location %>
            </span>
            <span>•</span>
            <span><%= @job.company.name %></span>
            <span>•</span>
            <span>Posted by <%= @job.posted_by_user.full_name %></span>
          </div>
        </div>
        <div class="flex space-x-3">
          <%= link_to admin_job_path(@job), 
              data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this job?" },
              class: "inline-flex items-center px-4 py-2 border border-red-300 rounded-md shadow-sm text-sm font-medium text-red-700 bg-white hover:bg-red-50" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Delete Job
          <% end %>
        </div>
      </div>
    </div>

    <!-- Job Stats -->
    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-4">
        <div class="bg-gray-50 p-4 rounded-lg">
          <dt class="text-sm font-medium text-gray-500">Views</dt>
          <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= @job.views_count %></dd>
        </div>
        <div class="bg-gray-50 p-4 rounded-lg">
          <dt class="text-sm font-medium text-gray-500">Applications</dt>
          <dd class="mt-1 text-3xl font-semibold text-indigo-600"><%= @job.applications_count %></dd>
        </div>
        <div class="bg-gray-50 p-4 rounded-lg">
          <dt class="text-sm font-medium text-gray-500">Posted</dt>
          <dd class="mt-1 text-sm font-semibold text-gray-900">
            <%= @job.published_at&.strftime('%b %d, %Y') || 'Not published' %>
          </dd>
        </div>
        <div class="bg-gray-50 p-4 rounded-lg">
          <dt class="text-sm font-medium text-gray-500">Expires</dt>
          <dd class="mt-1 text-sm font-semibold text-gray-900">
            <%= @job.expires_at&.strftime('%b %d, %Y') || 'No expiration' %>
          </dd>
        </div>
      </dl>
    </div>

    <!-- Job Details -->
    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500">Employment Type</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @job.employment_type.humanize %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Salary Range</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <%= @job.salary_range || 'Not specified' %>
          </dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-gray-500 mb-2">Description</dt>
          <dd class="mt-1 text-sm text-gray-900 prose max-w-none">
            <%= simple_format(@job.description) %>
          </dd>
        </div>
        <% if @job.skills.any? %>
          <div class="sm:col-span-2">
            <dt class="text-sm font-medium text-gray-500 mb-2">Required Skills</dt>
            <dd class="mt-1 flex flex-wrap gap-2">
              <% @job.skills.each do |skill| %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-100 text-indigo-800">
                  <%= skill.name %>
                </span>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <!-- Applications Section -->
  <% if @applications.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Applications (<%= @applications.count %>)
        </h3>
      </div>
      <div class="border-t border-gray-200">
        <ul class="divide-y divide-gray-200">
          <% @applications.limit(10).each do |application| %>
            <li class="px-4 py-4 hover:bg-gray-50">
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <div class="h-10 w-10 rounded-full bg-gradient-to-r from-blue-500 to-purple-600 flex items-center justify-center">
                    <span class="text-sm font-medium text-white">
                      <%= application.user.first_name.first.upcase %><%= application.user.last_name.first.upcase %>
                    </span>
                  </div>
                  <div class="ml-4">
                    <p class="text-sm font-medium text-gray-900"><%= application.user.full_name %></p>
                    <p class="text-sm text-gray-500"><%= application.user.email %></p>
                    <p class="text-xs text-gray-400">
                      Applied <%= time_ago_in_words(application.applied_at) %> ago
                    </p>
                  </div>
                </div>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                      <%= case application.status
                          when 'applied' then 'bg-blue-100 text-blue-800'
                          when 'viewed' then 'bg-yellow-100 text-yellow-800'
                          when 'shortlisted' then 'bg-green-100 text-green-800'
                          when 'rejected' then 'bg-red-100 text-red-800'
                          when 'hired' then 'bg-purple-100 text-purple-800'
                          end %>">
                  <%= application.status.humanize %>
                </span>
              </div>
            </li>
          <% end %>
        </ul>
        <% if @applications.count > 10 %>
          <div class="px-4 py-3 bg-gray-50 text-center text-sm text-gray-500">
            And <%= @applications.count - 10 %> more applications...
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>