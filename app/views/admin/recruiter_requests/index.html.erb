<section class="page-hero relative">
  <span class="page-kicker">Recruiter requests</span>
  <h1 class="page-title">Review company membership requests faster.</h1>
  <p class="page-subtitle">Pending, approved, and rejected recruiter access requests in one admin review queue.</p>
</section>

<section class="mb-8 stat-grid">
  <div class="stat-card"><p class="stat-label">Pending</p><p class="stat-value"><%= @stats[:total_pending] %></p></div>
  <div class="stat-card"><p class="stat-label">Approved</p><p class="stat-value"><%= @stats[:total_approved] %></p></div>
  <div class="stat-card"><p class="stat-label">Rejected</p><p class="stat-value"><%= @stats[:total_rejected] %></p></div>
</section>

<section class="space-y-5">
  <% if @requests.any? %>
    <% @requests.each do |request| %>
      <article class="section-card">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="text-2xl font-bold text-slate-900"><%= request.user.full_name %></h2>
              <span class="badge-pill <%= request.pending? ? "badge-amber" : request.approved? ? "badge-emerald" : "badge-red" %>"><%= request.status.humanize %></span>
            </div>
            <p class="mt-2 text-sm text-slate-500"><%= request.company.name %> • <%= request.role.humanize %></p>
            <p class="mt-3 text-xs uppercase tracking-[0.18em] text-slate-400">Requested <%= time_ago_in_words(request.created_at) %> ago</p>
          </div>
          <%= link_to "Open request", admin_recruiter_request_path(request), class: "btn-secondary" %>
        </div>
      </article>
    <% end %>
    <div class="mt-8"><%= paginate @requests if respond_to?(:paginate) %></div>
  <% else %>
    <div class="ui-empty-state"><p>There are no recruiter requests right now.</p></div>
  <% end %>
</section>
