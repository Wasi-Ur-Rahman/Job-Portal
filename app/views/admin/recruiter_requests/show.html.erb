<section class="section-card mb-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <span class="badge-pill <%= @request.pending? ? "badge-amber" : @request.approved? ? "badge-emerald" : "badge-red" %>"><%= @request.status.humanize %></span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @request.user.full_name %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @request.company.name %> • <%= @request.role.humanize %></p>
    </div>
    <% if @request.pending? %>
      <div class="flex flex-wrap gap-2">
        <%= button_to "Approve request", approve_admin_recruiter_request_path(@request), method: :patch, class: "btn-success" %>
        <%= button_to "Reject request", reject_admin_recruiter_request_path(@request), method: :patch, class: "btn-danger" %>
      </div>
    <% end %>
  </div>
</section>

<div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_320px]">
  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">Request details</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <div class="section-card-muted">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Applicant</p>
        <p class="mt-2 text-lg font-semibold text-slate-900"><%= @request.user.full_name %></p>
        <p class="mt-1 text-sm text-slate-500"><%= @request.user.email %></p>
      </div>
      <div class="section-card-muted">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Target company</p>
        <p class="mt-2 text-lg font-semibold text-slate-900"><%= @request.company.name %></p>
        <p class="mt-1 text-sm text-slate-500"><%= @request.company.location %> • <%= @request.company.industry %></p>
      </div>
      <% if @request.title.present? %>
        <div class="section-card-muted">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Position title</p>
          <p class="mt-2 text-lg font-semibold text-slate-900"><%= @request.title %></p>
        </div>
      <% end %>
      <% if @request.contact_info["experience"].present? %>
        <div class="section-card-muted">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Experience</p>
          <p class="mt-2 text-lg font-semibold text-slate-900"><%= @request.contact_info["experience"] %></p>
        </div>
      <% end %>
      <% if @request.contact_info["message"].present? %>
        <div class="section-card-muted md:col-span-2">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Message</p>
          <div class="prose mt-3 max-w-none"><%= simple_format(@request.contact_info["message"]) %></div>
        </div>
      <% end %>
    </div>
  </section>

  <aside class="section-card-muted h-fit">
    <h2 class="text-lg font-bold text-slate-900">Managers</h2>
    <% if @company_managers.any? %>
      <div class="mt-4 space-y-3">
        <% @company_managers.each do |manager_membership| %>
          <div class="rounded-2xl bg-white p-4 shadow-sm">
            <p class="font-semibold text-slate-900"><%= manager_membership.user.full_name %></p>
            <p class="mt-1 text-sm text-slate-500"><%= manager_membership.user.email %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="mt-3 text-sm text-slate-500">No managers found for this company.</p>
    <% end %>
  </aside>
</div>
