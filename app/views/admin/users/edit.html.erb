<section class="page-hero relative">
  <span class="page-kicker">Edit user</span>
  <h1 class="page-title">Update account details without leaving the admin flow.</h1>
  <p class="page-subtitle">Quick edit form for core identity and role changes.</p>
</section>

<section class="section-card max-w-3xl mx-auto">
  <%= form_with model: [:admin, @user], local: true, class: "space-y-6" do |f| %>
    <% if @user.errors.any? %>
      <div class="flash-banner alert">
        <div>
          <ul class="list-disc pl-5">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :first_name, class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= f.text_field :first_name %>
      </div>
      <div>
        <%= f.label :last_name, class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= f.text_field :last_name %>
      </div>
    </div>

    <div>
      <%= f.label :email, class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.email_field :email %>
    </div>

    <div>
      <%= f.label :role, class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.select :role, User.roles.keys.map { |role| [role.humanize, role] } %>
    </div>

    <div class="flex flex-col gap-3 border-t border-slate-200 pt-5 sm:flex-row sm:justify-between">
      <%= link_to "Cancel", admin_user_path(@user), class: "btn-secondary" %>
      <%= f.submit "Update user", class: "btn-primary" %>
    </div>
  <% end %>
</section>
