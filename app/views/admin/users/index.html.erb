<section class="page-hero relative">
  <span class="page-kicker">Users</span>
  <h1 class="page-title">Search and inspect platform accounts quickly.</h1>
  <p class="page-subtitle">Role counts, verification states, and lightweight actions in a cleaner data view.</p>
</section>

<section class="section-card mb-8">
  <%= form_with url: admin_users_path, method: :get, local: true, class: "flex flex-col gap-4 md:flex-row md:items-end md:justify-between" do |f| %>
    <div class="w-full md:max-w-md">
      <%= f.label :search, "Search users", class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.text_field :search, value: params[:search], placeholder: "Name or email" %>
    </div>
    <%= f.submit "Search", class: "btn-primary" %>
  <% end %>
</section>

<section class="mb-8 stat-grid">
  <%= link_to admin_users_path, class: "stat-card block" do %><p class="stat-label">All users</p><p class="stat-value"><%= User.count %></p><p class="stat-meta">Full account list.</p><% end %>
  <%= link_to admin_users_path(role: "job_seeker"), class: "stat-card block" do %><p class="stat-label">Job seekers</p><p class="stat-value"><%= @job_seekers_count %></p><p class="stat-meta">Candidate accounts.</p><% end %>
  <%= link_to admin_users_path(role: "recruiter"), class: "stat-card block" do %><p class="stat-label">Recruiters</p><p class="stat-value"><%= @recruiters_count %></p><p class="stat-meta">Hiring accounts.</p><% end %>
  <%= link_to admin_users_path(role: "admin"), class: "stat-card block" do %><p class="stat-label">Admins</p><p class="stat-value"><%= @admins_count %></p><p class="stat-meta">Platform operators.</p><% end %>
</section>

<section class="ui-table-wrap">
  <% if @users.any? %>
    <div class="ui-table-scroll">
      <table class="ui-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Role</th>
            <th>Status</th>
            <th>Activity</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td>
                <div class="font-semibold text-slate-900"><%= link_to user.full_name, admin_user_path(user), class: "hover:text-teal-700" %></div>
                <div class="text-sm text-slate-500"><%= user.email %></div>
              </td>
              <td><span class="badge-pill badge-blue"><%= user.role.humanize %></span></td>
              <td>
                <span class="badge-pill <%= user.confirmed_at.present? ? "badge-emerald" : "badge-amber" %>">
                  <%= user.confirmed_at.present? ? "Verified" : "Pending" %>
                </span>
              </td>
              <td class="text-slate-500">
                <% case user.role %>
                <% when "job_seeker" %>
                  <%= pluralize(user.applications.count, "application") %>
                <% when "recruiter" %>
                  <%= pluralize(user.posted_jobs.count, "job posted") %>
                <% when "admin" %>
                  <%= pluralize(user.approved_companies.count, "approval") %>
                <% end %>
              </td>
              <td class="text-slate-500"><%= user.created_at.strftime("%b %d, %Y") %></td>
              <td>
                <div class="flex flex-wrap gap-2">
                  <%= link_to "View", admin_user_path(user), class: "btn-ghost" %>
                  <%= link_to "Edit", edit_admin_user_path(user), class: "btn-secondary" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="px-6 pb-6 pt-4">
      <%= paginate @users if respond_to?(:paginate) %>
    </div>
  <% else %>
    <div class="ui-empty-state m-6"><p>No users matched this search.</p></div>
  <% end %>
</section>
