<section class="section-card mb-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <span class="badge-pill badge-blue"><%= @user.role.humanize %></span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @user.full_name %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @user.email %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit user", edit_admin_user_path(@user), class: "btn-primary" %>
      <% unless @user.admin? || @user == current_user %>
        <%= link_to "Delete user", admin_user_path(@user), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete #{@user.full_name}?" }, class: "btn-danger" %>
      <% end %>
    </div>
  </div>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    <div class="section-card-muted"><p class="text-xs uppercase tracking-[0.18em] text-slate-400">Username</p><p class="mt-2 text-lg font-semibold text-slate-900"><%= @user.username %></p></div>
    <div class="section-card-muted"><p class="text-xs uppercase tracking-[0.18em] text-slate-400">Verification</p><p class="mt-2 text-lg font-semibold text-slate-900"><%= @user.confirmed_at.present? ? "Verified" : "Pending" %></p></div>
    <div class="section-card-muted"><p class="text-xs uppercase tracking-[0.18em] text-slate-400">Location</p><p class="mt-2 text-lg font-semibold text-slate-900"><%= @user.location.presence || "Not provided" %></p></div>
    <div class="section-card-muted"><p class="text-xs uppercase tracking-[0.18em] text-slate-400">Member since</p><p class="mt-2 text-lg font-semibold text-slate-900"><%= @user.created_at.strftime("%B %d, %Y") %></p></div>
  </div>
</section>

<% case @user.role %>
<% when "job_seeker" %>
  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">Applications</h2>
    <% if @applications&.any? %>
      <div class="mt-5 space-y-4">
        <% @applications.limit(5).each do |application| %>
          <div class="section-card-muted">
            <h3 class="text-lg font-bold text-slate-900"><%= application.job.title %></h3>
            <p class="mt-2 text-sm text-slate-500"><%= application.job.company.name %> • <%= application.status.humanize %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="ui-empty-state mt-5"><p>No applications yet.</p></div>
    <% end %>
  </section>
<% when "recruiter" %>
  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">Recruiter footprint</h2>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <% @companies&.each do |company| %>
        <div class="section-card-muted">
          <h3 class="text-lg font-bold text-slate-900"><%= company.name %></h3>
          <p class="mt-2 text-sm text-slate-500"><%= company.location %> • <%= company.status.humanize %></p>
        </div>
      <% end %>
    </div>
  </section>
<% when "admin" %>
  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">Admin activity</h2>
    <div class="mt-5 stat-grid">
      <div class="stat-card"><p class="stat-label">Companies approved</p><p class="stat-value"><%= @user.approved_companies.count %></p></div>
      <div class="stat-card"><p class="stat-label">Admin actions</p><p class="stat-value"><%= @user.approved_companies.count %></p></div>
    </div>
  </section>
<% end %>
