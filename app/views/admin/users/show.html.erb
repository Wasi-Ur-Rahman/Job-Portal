<div class="px-4 py-6 sm:px-0">
  <div class="mb-6">
    <%= link_to admin_users_path, class: "inline-flex items-center text-indigo-600 hover:text-indigo-900" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to Users
    <% end %>
  </div>

  <!-- User Header -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
    <div class="px-4 py-5 sm:px-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="h-20 w-20 rounded-full bg-gradient-to-r from-indigo-500 to-purple-600 flex items-center justify-center">
            <span class="text-2xl font-bold text-white"><%= @user.first_name.first.upcase %><%= @user.last_name.first.upcase %></span>
          </div>
          <div class="ml-6">
            <h1 class="text-3xl font-bold text-gray-900"><%= @user.full_name %></h1>
            <div class="mt-1 flex items-center space-x-3">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium 
                    <%= case @user.role
                        when 'admin' then 'bg-purple-100 text-purple-800'
                        when 'recruiter' then 'bg-blue-100 text-blue-800'
                        when 'job_seeker' then 'bg-green-100 text-green-800'
                        end %>">
                <%= @user.role.humanize %>
              </span>
              <% if @user.confirmed_at.present? %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  Verified
                </span>
              <% end %>
            </div>
          </div>
        </div>
        <div class="flex space-x-3">
          <%= link_to edit_admin_user_path(@user), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit User
          <% end %>
          <% unless @user.admin? || @user == current_user %>
            <%= link_to admin_user_path(@user), 
                data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete #{@user.full_name}?" },
                class: "inline-flex items-center px-4 py-2 border border-red-300 rounded-md shadow-sm text-sm font-medium text-red-700 bg-white hover:bg-red-50" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
              Delete User
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Basic Info -->
    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500">Email Address</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.email %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Username</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.username %></dd>
        </div>
        <% if @user.location.present? %>
          <div>
            <dt class="text-sm font-medium text-gray-500">Location</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @user.location %></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-sm font-medium text-gray-500">Member Since</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.created_at.strftime('%B %d, %Y') %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Last Sign In</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <% if @user.last_sign_in_at.present? %>
              <%= time_ago_in_words(@user.last_sign_in_at) %> ago
            <% else %>
              Never
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Sign In Count</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.sign_in_count %> times</dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Role-specific Information -->
  <% case @user.role %>
  <% when 'job_seeker' %>
    <!-- Applications Section -->
    <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Applications (<%= @applications&.count || 0 %>)
        </h3>
      </div>
      <div class="border-t border-gray-200">
        <% if @applications&.any? %>
          <ul class="divide-y divide-gray-200">
            <% @applications.limit(5).each do |application| %>
              <li class="px-4 py-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-medium text-indigo-600"><%= application.job.title %></p>
                    <p class="text-sm text-gray-500"><%= application.job.company.name %></p>
                    <p class="text-xs text-gray-400">Applied <%= time_ago_in_words(application.applied_at) %> ago</p>
                  </div>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                        <%= case application.status
                            when 'applied' then 'bg-blue-100 text-blue-800'
                            when 'viewed' then 'bg-yellow-100 text-yellow-800'
                            when 'shortlisted' then 'bg-green-100 text-green-800'
                            when 'rejected' then 'bg-red-100 text-red-800'
                            when 'hired' then 'bg-purple-100 text-purple-800'
                            end %>">
                    <%= application.status.humanize %>
                  </span>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="px-4 py-6 text-center text-sm text-gray-500">
            No applications yet
          </div>
        <% end %>
      </div>
    </div>

    <!-- Bookmarks Section -->
    <% if @bookmarks&.any? %>
      <div class="bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">
            Bookmarked Jobs (<%= @bookmarks.count %>)
          </h3>
        </div>
        <div class="border-t border-gray-200">
          <ul class="divide-y divide-gray-200">
            <% @bookmarks.limit(5).each do |bookmark| %>
              <li class="px-4 py-4">
                <p class="text-sm font-medium text-gray-900"><%= bookmark.job.title %></p>
                <p class="text-sm text-gray-500"><%= bookmark.job.company.name %></p>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

  <% when 'recruiter' %>
    <!-- Companies Section -->
    <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Companies (<%= @companies&.count || 0 %>)
        </h3>
      </div>
      <div class="border-t border-gray-200">
        <% if @companies&.any? %>
          <ul class="divide-y divide-gray-200">
            <% @companies.each do |company| %>
              <li class="px-4 py-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-medium text-gray-900"><%= company.name %></p>
                    <p class="text-sm text-gray-500"><%= company.location %> • <%= company.industry %></p>
                  </div>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                        <%= case company.status
                            when 'pending' then 'bg-yellow-100 text-yellow-800'
                            when 'approved' then 'bg-green-100 text-green-800'
                            when 'rejected' then 'bg-red-100 text-red-800'
                            end %>">
                    <%= company.status.humanize %>
                  </span>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="px-4 py-6 text-center text-sm text-gray-500">
            No companies yet
          </div>
        <% end %>
      </div>
    </div>

    <!-- Posted Jobs Section -->
    <% if @posted_jobs&.any? %>
      <div class="bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">
            Posted Jobs (<%= @posted_jobs.count %>)
          </h3>
        </div>
        <div class="border-t border-gray-200">
          <ul class="divide-y divide-gray-200">
            <% @posted_jobs.limit(5).each do |job| %>
              <li class="px-4 py-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-medium text-gray-900"><%= job.title %></p>
                    <p class="text-sm text-gray-500">
                      <%= job.company.name %> • <%= pluralize(job.applications_count, 'application') %>
                    </p>
                  </div>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                        <%= case job.status
                            when 'draft' then 'bg-gray-100 text-gray-800'
                            when 'published' then 'bg-green-100 text-green-800'
                            when 'closed' then 'bg-red-100 text-red-800'
                            end %>">
                    <%= job.status.humanize %>
                  </span>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

  <% when 'admin' %>
    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">Admin Activity</h3>
      </div>
      <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-gray-500">Companies Approved</dt>
            <dd class="mt-1 text-2xl font-semibold text-gray-900">
              <%= @user.approved_companies.count %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Total Admin Actions</dt>
            <dd class="mt-1 text-2xl font-semibold text-gray-900">
              <%= @user.approved_companies.count %>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  <% end %>
</div>