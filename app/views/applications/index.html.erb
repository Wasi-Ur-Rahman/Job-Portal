<%# Helper method for status badge colors (could be moved to a helper file) %>
<%
  def status_badge_classes(status)
    case status
    when 'interviewing'
      'bg-yellow-100 text-yellow-800 ring-yellow-600/20'
    when 'offered'
      'bg-green-100 text-green-700 ring-green-600/20'
    when 'rejected'
      'bg-red-100 text-red-700 ring-red-600/20'
    when 'withdrawn'
      'bg-gray-100 text-gray-600 ring-gray-500/20'
    else # applied
      'bg-blue-100 text-blue-700 ring-blue-600/20'
    end
  end
%>

<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-8">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">My Applications</h1>
    <% if @applications.any? %>
      <p class="text-gray-500 mt-2 sm:mt-0">You have <%= pluralize(@applications.total_count, 'application') %>.</p>
    <% end %>
  </div>

  <% if @applications.any? %>
    <div class="space-y-6">
      <% @applications.each do |application| %>
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm hover:shadow-lg transition-shadow duration-300 p-4 sm:p-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 h-16 w-16 bg-gray-100 rounded-lg flex items-center justify-center">
              <%# Placeholder for a real logo: image_tag(application.job.company.logo_url) %>
              <span class="text-2xl font-bold text-indigo-600"><%= application.job.company.name[0] %></span>
            </div>

            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start">
                <div>
                  <h2 class="text-xl font-semibold text-gray-900">
                    <%= link_to application.job.title, job_path(application.job), class: "hover:text-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded" %>
                  </h2>
                  <p class="text-gray-600 text-sm mt-1">
                    <%= application.job.company.name %> • <%= application.job.location %>
                    <% if application.job.is_remote %>• <span class="font-medium text-green-600">Remote</span><% end %>
                  </p>
                  <p class="text-gray-400 text-xs mt-2">Applied on: <%= application.applied_at.strftime("%B %d, %Y") %></p>
                </div>

                <div class="mt-3 sm:mt-0 sm:ml-4 flex-shrink-0">
                  <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= status_badge_classes(application.status) %>">
                    <%= application.status.humanize %>
                  </span>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-4 pt-4 border-t border-gray-200 flex flex-col sm:flex-row sm:items-center sm:justify-end gap-3">
             <%= link_to "View Details", application_path(application),
                  class: "w-full sm:w-auto text-center px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors" %>

            <% if application.status == 'applied' %>
              <%= button_to withdraw_application_path(application), method: :patch,
                    class: "w-full sm:w-auto text-center px-4 py-2 bg-white text-gray-700 border border-gray-300 rounded-lg text-sm font-semibold hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors",
                    data: { confirm: "Are you sure you want to withdraw this application?" } do %>
                Withdraw
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-10">
      <%= paginate @applications %>
    </div>

  <% else %>
    <div class="text-center py-16 px-4 border-2 border-dashed border-gray-300 rounded-2xl">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
      </svg>
      <h3 class="mt-2 text-lg font-medium text-gray-900">No applications yet</h3>
      <p class="mt-1 text-gray-500">Get started by searching for your next opportunity.</p>
      <div class="mt-6">
        <%= link_to "Browse Jobs", jobs_path,
              class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-xl shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    </div>
  <% end %>
</div>