<section class="page-hero relative">
  <span class="page-kicker">My pipeline</span>
  <h1 class="page-title">Track every application in one place.</h1>
  <p class="page-subtitle">Clear status chips, compact company context, and fast access back to the roles you’ve already moved on.</p>
</section>

<section class="mb-8 stat-grid">
  <div class="stat-card">
    <p class="stat-label">Applications</p>
    <p class="stat-value"><%= @applications.total_count %></p>
    <p class="stat-meta">Total roles you’ve submitted to.</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Active</p>
    <p class="stat-value"><%= @applications.count { |application| application.status != "withdrawn" && application.status != "rejected" } %></p>
    <p class="stat-meta">Still in consideration or moving.</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Interviews / offers</p>
    <p class="stat-value"><%= @applications.count { |application| %w[interviewing offered].include?(application.status) } %></p>
    <p class="stat-meta">Closer to the finish line.</p>
  </div>
</section>

<% if @applications.any? %>
  <div class="space-y-5">
    <% @applications.each do |application| %>
      <% badge_class =
        case application.status
        when "interviewing" then "badge-pill badge-amber"
        when "offered" then "badge-pill badge-emerald"
        when "rejected" then "badge-pill badge-red"
        when "withdrawn" then "badge-pill badge-slate"
        else "badge-pill badge-blue"
        end %>

      <article class="section-card">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
          <div class="flex flex-1 gap-4">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-teal-100 text-2xl font-bold text-teal-700">
              <%= application.job.company.name.first %>
            </div>

            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-3">
                <h2 class="text-2xl font-bold text-slate-900">
                  <%= link_to application.job.title, job_path(application.job), class: "hover:text-teal-700" %>
                </h2>
                <span class="<%= badge_class %>"><%= application.status.humanize %></span>
              </div>
              <p class="mt-2 text-sm font-semibold text-slate-600"><%= application.job.company.name %> • <%= application.job.location %></p>
              <p class="mt-3 text-sm text-slate-500">Applied on <%= application.applied_at.strftime("%B %d, %Y") %></p>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 lg:justify-end">
            <%= link_to "View details", application_path(application), class: "btn-primary" %>
            <% if application.status == "applied" %>
              <%= button_to withdraw_application_path(application), method: :patch, data: { confirm: "Are you sure you want to withdraw this application?" }, class: "btn-secondary" do %>
                Withdraw
              <% end %>
            <% end %>
          </div>
        </div>
      </article>
    <% end %>
  </div>

  <div class="mt-8">
    <%= paginate @applications %>
  </div>
<% else %>
  <div class="ui-empty-state">
    <h3 class="text-lg font-semibold text-slate-900">No applications yet</h3>
    <p class="mt-2">Start applying to roles and the pipeline will build itself here.</p>
    <div class="mt-5">
      <%= link_to "Browse jobs", jobs_path, class: "btn-primary" %>
    </div>
  </div>
<% end %>
