<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
  <%# -- Page Header (No changes here) -- %>
  <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 mb-8">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
      <div>
        <p class="text-sm font-medium text-indigo-600">Application Details</p>
        <h1 class="mt-1 text-4xl font-bold tracking-tight text-gray-900"><%= @application.job.title %></h1>
        <p class="mt-2 text-lg text-gray-500">
          at <%= @application.job.company.name %>
        </p>
        <div class="mt-4 flex items-center gap-x-4 text-sm text-gray-500">
          <span>Applied on <%= @application.applied_at.strftime("%B %d, %Y") %></span>
          <div class="w-px h-4 bg-gray-300"></div>
          <span class="inline-flex items-center rounded-md bg-blue-100 px-2 py-1 font-medium text-blue-700 ring-1 ring-inset ring-blue-600/20">
            Status: <%= @application.status.humanize %>
          </span>
        </div>
      </div>
      <div class="flex-shrink-0 mt-4 md:mt-0 flex flex-row-reverse md:flex-col items-center gap-3">
         <%= link_to "Back to Applications", applications_path,
              class: "w-full md:w-auto text-center px-4 py-2 bg-white text-gray-700 border border-gray-300 rounded-lg text-sm font-semibold hover:bg-gray-50" %>
        <% if @application.status == 'applied' %>
          <%= button_to withdraw_application_path(@application), method: :patch,
                class: "w-full md:w-auto text-center px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-semibold hover:bg-red-700",
                data: { confirm: "Are you sure you want to withdraw this application?" } do %>
            Withdraw
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# -- Main Content Grid -- %>
  <div class="grid grid-cols-1 lg:grid-cols-3 lg:gap-8">
    <%# -- Left Column: Job Description -- %>
    <div class="lg:col-span-2 bg-white border border-gray-200 rounded-2xl p-6">
      <%# START: MODIFIED SECTION FOR "SHOW MORE/LESS" %>
      <div
        x-data="{ expanded: false, isTall: false }"
        x-init="isTall = $refs.content.scrollHeight > 256"
        class="relative"
      >
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Job Description</h2>
        <div
          x-ref="content"
          class="prose prose-indigo max-w-none text-gray-600 transition-all duration-500 ease-in-out"
          :class="!expanded && isTall ? 'max-h-64 overflow-hidden' : 'max-h-none'"
        >
          <%= simple_format(@application.job.description) %>
        </div>

        <%# Gradient overlay for truncated view %>
        <div x-show="!expanded && isTall" x-transition class="absolute bottom-0 left-0 w-full h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>

        <%# "Show More" / "Show Less" Button %>
        <div x-show="isTall" class="mt-4">
          <button @click="expanded = !expanded" type="button" class="inline-flex items-center text-sm font-semibold text-indigo-600 hover:text-indigo-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded">
            <span x-text="expanded ? 'Show Less' : 'Show More'">Show More</span>
            <svg class="ml-1 h-5 w-5 transform transition-transform duration-200" :class="{ 'rotate-180': expanded }" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      </div>
      <%# END: MODIFIED SECTION %>
    </div>

    <%# -- Right Column: Key Details Sidebar (No changes here) -- %>
    <div class="mt-8 lg:mt-0">
      <div class="bg-white border border-gray-200 rounded-2xl p-6">
        <h2 class="text-xl font-semibold text-gray-900">Key Details</h2>
        <ul class="mt-4 space-y-4 text-gray-600">
          <li class="flex items-start">
            <svg class="h-6 w-6 text-gray-400 flex-shrink-0 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>
            <span><%= @application.job.company.name %></span>
          </li>
          <li class="flex items-start">
             <svg class="h-6 w-6 text-gray-400 flex-shrink-0 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            <span><%= @application.job.location %></span>
          </li>
          <% if @application.job.is_remote %>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-green-500 flex-shrink-0 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.045A9 9 0 015.657 12c0-2.064.713-3.962 1.935-5.481M15.75 4.5c.593 0 1.171.047 1.737.139M18.343 12c0 2.064-.713 3.962-1.935 5.481m-2.121-2.121a3 3 0 10-4.242-4.242 3 3 0 004.242 4.242z" /></svg>
              <span class="font-semibold text-green-600">Remote work available</span>
            </li>
          <% end %>
          <% if @application.job.salary_range.present? %>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-gray-400 flex-shrink-0 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span><%= @application.job.salary_range %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
