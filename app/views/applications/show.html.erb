<section class="section-card mb-8">
  <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
    <div>
      <span class="badge-pill badge-blue">Application details</span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @application.job.title %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @application.job.company.name %></p>
      <p class="mt-4 text-sm text-slate-500">Applied on <%= @application.applied_at.strftime("%B %d, %Y") %></p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Back to applications", applications_path, class: "btn-secondary" %>
      <% if @application.status == "applied" %>
        <%= button_to withdraw_application_path(@application), method: :patch, data: { confirm: "Are you sure you want to withdraw this application?" }, class: "btn-danger" do %>
          Withdraw
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_320px]">
  <section class="section-card">
    <div data-controller="expandable" data-expandable-max-height-value="256" class="relative">
      <h2 class="text-2xl font-bold text-slate-900">Job description</h2>
      <div data-expandable-target="content" class="prose mt-5 max-w-none transition-all duration-300">
        <%= simple_format(@application.job.description) %>
      </div>
      <div data-expandable-target="overlay" class="absolute inset-x-0 bottom-14 hidden h-24 bg-gradient-to-t from-white to-transparent"></div>
      <div data-expandable-target="toggle" class="mt-5 hidden">
        <button type="button" data-action="expandable#toggle" class="btn-ghost">
          <span data-expandable-target="label">Show More</span>
        </button>
      </div>
    </div>
  </section>

  <aside class="space-y-6">
    <section class="section-card-muted">
      <h2 class="text-lg font-bold text-slate-900">Application snapshot</h2>
      <dl class="mt-4 space-y-4 text-sm">
        <div class="flex items-center justify-between gap-3">
          <dt class="text-slate-500">Status</dt>
          <dd class="badge-pill badge-blue"><%= @application.status.humanize %></dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="text-slate-500">Company</dt>
          <dd class="font-semibold text-slate-900"><%= @application.job.company.name %></dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="text-slate-500">Location</dt>
          <dd class="font-semibold text-slate-900"><%= @application.job.location %></dd>
        </div>
        <% if @application.job.salary_range.present? %>
          <div class="flex items-center justify-between gap-3">
            <dt class="text-slate-500">Salary</dt>
            <dd class="font-semibold text-slate-900"><%= @application.job.salary_range %></dd>
          </div>
        <% end %>
      </dl>
    </section>
  </aside>
</div>
