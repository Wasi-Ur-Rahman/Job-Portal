<section class="page-hero relative">
  <span class="page-kicker">Saved roles</span>
  <h1 class="page-title">Keep good opportunities nearby.</h1>
  <p class="page-subtitle">Bookmark roles that need a second pass, then return with more context and less friction.</p>
</section>

<% if @bookmarks.any? %>
  <div class="grid gap-5">
    <% @bookmarks.each do |bookmark| %>
      <% job = bookmark.job %>
      <article class="section-card">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="text-2xl font-bold text-slate-900">
                <%= link_to job.title, job_path(job), class: "hover:text-teal-700" %>
              </h2>
              <span class="badge-pill badge-blue"><%= job.employment_type.humanize %></span>
              <% if job.is_remote %>
                <span class="badge-pill badge-emerald">Remote</span>
              <% end %>
            </div>

            <p class="mt-2 text-sm font-semibold text-slate-600"><%= job.company.name %> • <%= job.location %></p>
            <% if job.salary_range.present? %>
              <p class="mt-3 text-sm text-slate-500">Compensation: <%= job.salary_range %></p>
            <% end %>

            <div class="mt-4 flex flex-wrap gap-2">
              <% job.skills.limit(4).each do |skill| %>
                <span class="badge-pill badge-blue"><%= skill.name %></span>
              <% end %>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            <%= link_to "View details", job_path(job), class: "btn-primary" %>
            <%= button_to bookmark_path(bookmark), method: :delete, data: { confirm: "Remove this job from bookmarks?" }, class: "btn-secondary" do %>
              Remove
            <% end %>
          </div>
        </div>
      </article>
    <% end %>
  </div>

  <div class="mt-8">
    <%= paginate @bookmarks %>
  </div>
<% else %>
  <div class="ui-empty-state">
    <h3 class="text-lg font-semibold text-slate-900">No saved roles yet</h3>
    <p class="mt-2">Bookmark promising jobs and build your shortlist here.</p>
    <div class="mt-5">
      <%= link_to "Browse jobs", jobs_path, class: "btn-primary" %>
    </div>
  </div>
<% end %>
