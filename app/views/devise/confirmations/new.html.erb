<section class="auth-shell">
  <div class="auth-grid">
    <div class="auth-copy">
      <span class="page-kicker">Verification</span>
      <h1 class="mt-5 text-5xl font-bold">Resend your confirmation email.</h1>
      <p class="mt-5 max-w-lg text-sm leading-8 text-white/80">If the first email expired or got buried, send a fresh verification link here.</p>
    </div>

    <div class="auth-card">
      <h2 class="text-3xl font-bold text-slate-900">Confirmation instructions</h2>

      <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "mt-8 space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <div>
          <%= f.label :email, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email) %>
        </div>
        <%= f.submit "Resend confirmation instructions", class: "btn-primary w-full" %>
      <% end %>

      <div class="mt-6 border-t border-slate-200 pt-5">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
