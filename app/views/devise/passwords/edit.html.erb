<section class="auth-shell">
  <div class="auth-grid">
    <div class="auth-copy">
      <span class="page-kicker">New password</span>
      <h1 class="mt-5 text-5xl font-bold">Set a stronger password and get back in.</h1>
      <p class="mt-5 max-w-lg text-sm leading-8 text-white/80">This is a focused one-step reset, without extra page noise.</p>
    </div>

    <div class="auth-card">
      <h2 class="text-3xl font-bold text-slate-900">Choose a new password</h2>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "mt-8 space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div>
          <%= f.label :password, "New password", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password" %>
          <% if @minimum_password_length %>
            <p class="mt-2 text-sm text-slate-500"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm new password", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
        </div>

        <%= f.submit "Change password", class: "btn-primary w-full" %>
      <% end %>

      <div class="mt-6 border-t border-slate-200 pt-5">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
