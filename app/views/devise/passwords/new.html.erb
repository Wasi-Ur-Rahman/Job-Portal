<section class="auth-shell">
  <div class="auth-grid">
    <div class="auth-copy">
      <span class="page-kicker">Password reset</span>
      <h1 class="mt-5 text-5xl font-bold">Recover access without the usual friction.</h1>
      <p class="mt-5 max-w-lg text-sm leading-8 text-white/80">Send the reset link to your inbox and finish the process in a cleaner flow.</p>
    </div>

    <div class="auth-card">
      <h2 class="text-3xl font-bold text-slate-900">Forgot password?</h2>
      <p class="mt-2 text-sm text-slate-500">Enter the email attached to your account.</p>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-8 space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <div>
          <%= f.label :email, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
        </div>
        <%= f.submit "Send reset instructions", class: "btn-primary w-full" %>
      <% end %>

      <div class="mt-6 border-t border-slate-200 pt-5">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
