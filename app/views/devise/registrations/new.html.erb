<section class="auth-shell">
  <div class="auth-grid">
    <div class="auth-copy">
      <span class="page-kicker">Get started</span>
      <h1 class="mt-5 text-5xl font-bold">Create the account that matches how you work.</h1>
      <p class="mt-5 max-w-lg text-sm leading-8 text-white/80">Job seekers get a faster application flow. Recruiters get a cleaner hiring workspace. One account structure, two distinct paths.</p>
    </div>

    <div class="auth-card">
      <h2 class="text-3xl font-bold text-slate-900">Create account</h2>
      <p class="mt-2 text-sm text-slate-500">
        Already have one?
        <%= link_to "Sign in", new_session_path(resource_name), class: "text-teal-700 hover:text-teal-800" %>
      </p>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), local: true, class: "mt-8 space-y-5") do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :first_name, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= f.text_field :first_name, required: true, autofocus: true %>
          </div>
          <div>
            <%= f.label :last_name, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= f.text_field :last_name, required: true %>
          </div>
        </div>

        <div>
          <%= f.label :email, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.email_field :email, required: true, autocomplete: "email" %>
        </div>

        <div>
          <%= f.label :username, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.text_field :username, required: true %>
        </div>

        <div>
          <%= f.label :role, "I’m joining as", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <div class="grid gap-3">
            <% [["job_seeker", "Job seeker", "Discover roles and manage applications."], ["recruiter", "Recruiter", "Post jobs and review candidates."]].each do |role, title, copy| %>
              <label class="section-card-muted flex cursor-pointer items-start gap-3">
                <%= f.radio_button :role, role, class: "mt-1" %>
                <span>
                  <span class="block text-base font-bold text-slate-900"><%= title %></span>
                  <span class="mt-1 block text-sm text-slate-500"><%= copy %></span>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <div>
          <%= f.label :password, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.password_field :password, required: true, autocomplete: "new-password" %>
          <% if @minimum_password_length %>
            <p class="mt-2 text-sm text-slate-500"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
        </div>

        <%= f.submit "Create account", class: "btn-primary w-full" %>
      <% end %>
    </div>
  </div>
</section>
