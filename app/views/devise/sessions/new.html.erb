<section class="auth-shell">
  <div class="auth-grid">
    <div class="auth-copy">
      <span class="page-kicker">Welcome back</span>
      <h1 class="mt-5 text-5xl font-bold">Sign in and keep your search moving.</h1>
      <p class="mt-5 max-w-lg text-sm leading-8 text-white/80">Turbo keeps navigation sharp, Stimulus handles the small interactions, and your applications stay in one flow without bouncing through clunky pages.</p>
    </div>

    <div class="auth-card">
      <h2 class="text-3xl font-bold text-slate-900">Log in</h2>
      <p class="mt-2 text-sm text-slate-500">
        Need an account?
        <%= link_to "Create one", new_registration_path(resource_name), class: "text-teal-700 hover:text-teal-800" %>
      </p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
        </div>

        <div>
          <%= f.label :password, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.password_field :password, autocomplete: "current-password" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="flex items-center gap-3 text-sm font-semibold text-slate-700">
            <%= f.check_box :remember_me %>
            <span>Remember me</span>
          </label>
        <% end %>

        <%= f.submit "Log in", class: "btn-primary w-full" %>
      <% end %>

      <div class="mt-6 border-t border-slate-200 pt-5">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
