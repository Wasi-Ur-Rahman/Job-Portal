<section class="auth-shell">
  <div class="auth-grid">
    <div class="auth-copy">
      <span class="page-kicker">Account unlock</span>
      <h1 class="mt-5 text-5xl font-bold">Request a new unlock link.</h1>
      <p class="mt-5 max-w-lg text-sm leading-8 text-white/80">If your account was locked after failed attempts, this gets you back to a clean sign-in path.</p>
    </div>

    <div class="auth-card">
      <h2 class="text-3xl font-bold text-slate-900">Unlock instructions</h2>

      <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "mt-8 space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <div>
          <%= f.label :email, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
        </div>
        <%= f.submit "Resend unlock instructions", class: "btn-primary w-full" %>
      <% end %>

      <div class="mt-6 border-t border-slate-200 pt-5">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
