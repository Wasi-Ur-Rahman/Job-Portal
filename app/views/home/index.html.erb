<section class="page-hero relative">
  <span class="page-kicker">Career platform</span>
  <h1 class="page-title">Find work that actually moves your career forward.</h1>
  <p class="page-subtitle">
    Explore high-signal roles, track applications clearly, and give recruiters a cleaner hiring workspace from the same product.
  </p>

  <div class="mt-8 flex flex-col gap-3 sm:flex-row">
    <%= link_to "Browse open jobs", jobs_path, class: "btn-primary" %>
    <% unless user_signed_in? %>
      <%= link_to "Create account", new_user_registration_path, class: "btn-secondary" %>
    <% end %>
  </div>
</section>

<section class="mb-8 stat-grid">
  <div class="stat-card">
    <p class="stat-label">Fresh opportunities</p>
    <p class="stat-value"><%= @latest_jobs.count %></p>
    <p class="stat-meta">Recently published roles from active companies.</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Remote-friendly</p>
    <p class="stat-value"><%= @latest_jobs.count(&:is_remote) %></p>
    <p class="stat-meta">Openings that support distributed teams.</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Hiring teams</p>
    <p class="stat-value"><%= @latest_jobs.map(&:company).uniq.count %></p>
    <p class="stat-meta">Companies actively posting roles right now.</p>
  </div>
</section>

<section class="section-card">
  <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <span class="badge-pill badge-teal">Latest roles</span>
      <h2 class="mt-3 text-3xl font-bold text-slate-900">Curated from the newest listings</h2>
      <p class="mt-2 max-w-2xl text-sm text-slate-500">Fast scan layout, clearer compensation signals, and skill tags that help applicants qualify themselves quickly.</p>
    </div>
    <%= link_to "See all jobs", jobs_path, class: "btn-ghost" %>
  </div>

  <div class="grid gap-5 lg:grid-cols-3">
    <% @latest_jobs.each do |job| %>
      <article class="section-card-muted flex h-full flex-col">
        <div class="mb-4 flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-semibold text-teal-700"><%= job.company.name %></p>
            <h3 class="mt-2 text-xl font-bold text-slate-900">
              <%= link_to job.title, job_path(job), class: "hover:text-teal-700" %>
            </h3>
          </div>
          <% if job.is_remote %>
            <span class="badge-pill badge-emerald">Remote</span>
          <% end %>
        </div>

        <p class="text-sm text-slate-500"><%= job.location %> <%= "• #{job.employment_type.humanize}" if job.employment_type.present? %></p>
        <p class="mt-4 flex-1 text-sm leading-7 text-slate-600"><%= truncate(strip_tags(job.description), length: 155) %></p>

        <div class="mt-4 flex flex-wrap gap-2">
          <% job.skills.limit(4).each do |skill| %>
            <span class="badge-pill badge-blue"><%= skill.name %></span>
          <% end %>
        </div>

        <div class="mt-6 flex items-center justify-between">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Posted <%= time_ago_in_words(job.published_at || job.created_at) %> ago</p>
          <%= link_to "Open role", job_path(job), class: "btn-secondary" %>
        </div>
      </article>
    <% end %>

    <% if @latest_jobs.empty? %>
      <div class="ui-empty-state lg:col-span-3">
        <h3 class="text-lg font-semibold text-slate-900">No live jobs yet</h3>
        <p class="mt-2">Once companies publish openings, they’ll appear here.</p>
      </div>
    <% end %>
  </div>
</section>
