<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Recommendations</title>
    <style>
      body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
      .container { max-width: 600px; margin: 0 auto; padding: 20px; }
      .header { background: #4f46e5; color: white; padding: 20px; text-align: center; }
      .job-card { border: 1px solid #e5e7eb; margin: 15px 0; padding: 20px; border-radius: 8px; }
      .job-title { font-size: 18px; font-weight: bold; color: #4f46e5; margin-bottom: 5px; }
      .job-company { color: #6b7280; margin-bottom: 10px; }
      .job-details { font-size: 14px; color: #374151; margin-bottom: 15px; }
      .btn { background: #4f46e5; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block; }
      .footer { margin-top: 40px; padding-top: 20px; border-top: 1px solid #e5e7eb; font-size: 12px; color: #6b7280; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Job Recommendations</h1>
        <p>Hi <%= @user.first_name %>, we found <%= @jobs.count %> jobs that might interest you!</p>
      </div>

      <% @jobs.each do |job| %>
        <div class="job-card">
          <div class="job-title"><%= job.title %></div>
          <div class="job-company">
            <%= job.company.name %> • <%= job.location %>
            <% if job.is_remote %>• Remote<% end %>
          </div>
          <div class="job-details">
            <%= truncate(strip_tags(job.description), length: 150) %>
          </div>
          <div class="job-details">
            <strong>Employment Type:</strong> <%= job.employment_type.humanize %><br>
            <% if job.salary_range %>
              <strong>Salary:</strong> <%= job.salary_range %><br>
            <% end %>
            <% if job.skills.any? %>
              <strong>Skills:</strong> <%= job.skills.limit(5).pluck(:name).join(', ') %>
              <% if job.skills.count > 5 %>
                and <%= job.skills.count - 5 %> more
              <% end %>
            <% end %>
          </div>
          <a href="<%= job_url(job) %>" class="btn">View Job Details</a>
        </div>
      <% end %>
    </div>
  </body>
</html>