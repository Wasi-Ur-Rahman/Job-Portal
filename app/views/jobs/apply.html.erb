<section class="page-hero relative">
  <span class="page-kicker">Application</span>
  <h1 class="page-title">Apply for <%= @job.title %></h1>
  <p class="page-subtitle"><%= @job.company.name %> • <%= @job.location %></p>
</section>

<div class="grid gap-8 lg:grid-cols-[minmax(0,1.5fr)_340px]">
  <section class="section-card">
    <%= form_with model: @application, url: submit_application_job_path(@job), local: true, multipart: true, class: "space-y-6" do |f| %>
      <% if @application.errors.any? %>
        <div class="flash-banner alert">
          <div>
            <p class="font-semibold">Please fix the following</p>
            <ul class="mt-2 list-disc pl-5">
              <% @application.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <div>
        <%= f.label :resume, "Resume", class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= f.file_field :resume, accept: ".pdf,.doc,.docx", required: true %>
        <p class="mt-2 text-sm text-slate-500">PDF or Word document, up to 5MB.</p>
      </div>

      <% if current_user.resume.attached? %>
        <div class="section-card-muted">
          <p class="text-sm font-semibold text-slate-800">Current profile resume</p>
          <p class="mt-1 text-sm text-slate-500"><%= current_user.resume.filename %></p>
        </div>
      <% end %>

      <div>
        <%= f.label :cover_letter, class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= f.text_area :cover_letter, rows: 10, required: true, placeholder: "Why this role, why this company, and why you?" %>
        <p class="mt-2 text-sm text-slate-500">Aim for clear signal: relevant experience, impact, and motivation.</p>
      </div>

      <div class="flex flex-col gap-3 border-t border-slate-200 pt-5 sm:flex-row sm:justify-between">
        <%= link_to "Cancel", job_path(@job), class: "btn-secondary" %>
        <%= f.submit "Submit application", class: "btn-primary" %>
      </div>
    <% end %>
  </section>

  <aside class="section-card-muted h-fit">
    <h2 class="text-lg font-bold text-slate-900">Before you send</h2>
    <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
      <li>Use a resume tailored to this role.</li>
      <li>Keep the cover letter specific to the job and company.</li>
      <li>Call out measurable wins, not only responsibilities.</li>
    </ul>
  </aside>
</div>
