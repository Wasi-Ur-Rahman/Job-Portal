<div class="bg-gray-50 min-h-screen">

  <!-- Search & Filters Section -->
  <section class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6 text-center">Find Your Dream Job</h1>

    <%= form_with url: jobs_path, method: :get, local: true, class: "bg-white rounded-3xl shadow-xl p-6" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4 items-end">
        <div class="md:col-span-2">
          <%= f.text_field :search,
            value: params[:search],
            placeholder: "Job title, company, or keywords...",
            class: "w-full border border-gray-300 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm" %>
        </div>

        <div>
          <%= f.text_field :location,
            value: params[:location],
            placeholder: "Location",
            class: "w-full border border-gray-300 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm" %>
        </div>

        <div>
          <%= f.select :employment_type, @employment_types, { prompt: 'Employment Type', selected: params[:employment_type] },
            class: "w-full border border-gray-300 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm" %>
        </div>

        <div>
          <%= f.submit "Search Jobs",
            class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-xl shadow-lg transition duration-200" %>
        </div>
      </div>

      <!-- Advanced Filters -->
      <details class="mt-4">
        <summary class="cursor-pointer text-sm font-medium text-gray-600 hover:text-gray-800 flex items-center justify-center">
          Advanced Filters 
          <svg class="ml-1 w-4 h-4 inline-block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
        </summary>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mt-4 pt-4 border-t border-gray-200">
          <%= f.select :industry, @industries.map { |i| [i, i] }, { prompt: 'Industry', selected: params[:industry] },
            class: "w-full border border-gray-300 rounded-xl py-2 px-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm" %>

          <%= f.number_field :salary_min, value: params[:salary_min], placeholder: "Min Salary",
            class: "w-full border border-gray-300 rounded-xl py-2 px-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm" %>

          <label class="flex items-center space-x-2">
            <%= f.check_box :remote,
                { class: "rounded border-gray-300 text-indigo-600 shadow-sm focus:ring-indigo-500",
                  checked: params[:remote] == 'true' },
                'true', '' %>
            <span class="text-sm text-gray-700">Remote Only</span>
          </label>
        </div>
      </details>
    <% end %>
  </section>

  <!-- Results Section -->
  <section class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row md:justify-between md:items-center mb-8">
      <h2 class="text-xl font-semibold text-gray-900">
        <%= @jobs.total_count %> Jobs Found
      </h2>

      <div class="flex items-center space-x-4 mt-4 md:mt-0">
        <%= form_with url: jobs_path, method: :get, local: true, class: "flex items-center space-x-2" do |f| %>
          <%= hidden_field_tag :search, params[:search] %>
          <%= hidden_field_tag :location, params[:location] %>
          <%= hidden_field_tag :employment_type, params[:employment_type] %>
          <%= hidden_field_tag :industry, params[:industry] %>
          <%= hidden_field_tag :salary_min, params[:salary_min] %>
          <%= hidden_field_tag :remote, params[:remote] %>

          <label class="text-sm text-gray-600">Sort by:</label>
          <%= f.select :sort,
              [['Newest', 'newest'], ['Oldest', 'oldest'], ['Highest Salary', 'salary_high'], ['Lowest Salary', 'salary_low'], ['Company Name', 'company']],
              { selected: params[:sort] || 'newest' },
              { class: "rounded-xl border border-gray-300 py-2 px-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm", onchange: "this.form.submit();" } %>
        <% end %>

        <%= link_to jobs_path, class: "text-sm text-indigo-600 hover:text-indigo-900" do %>
          Clear Filters
        <% end %>
      </div>
    </div>

    <!-- Job Listings -->
    <div class="grid gap-6">
      <% @jobs.each do |job| %>
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm hover:shadow-md transition">
          <div class="p-6 flex flex-col sm:flex-row sm:justify-between sm:items-start gap-6">
            <!-- Left: Job Info -->
            <div class="flex-1">
              <div class="flex items-center gap-4">
                <% if job.company.logo.attached? %>
                  <%= image_tag job.company.logo, class: "h-16 w-16 rounded-lg object-cover mr-4" %>
                <% else %>
                  <div class="h-16 w-16 bg-gray-200 rounded-lg flex items-center justify-center mr-4">
                    <span class="text-lg font-medium text-gray-600"><%= job.company.name.first.upcase %></span>
                  </div>
                <% end %>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 hover:text-indigo-600">
                    <%= link_to job.title, job_path(job) %>
                  </h3>
                  <p class="text-sm text-gray-600">
                    <%= job.company.name %> • <%= job.location %>
                    <% if job.is_remote %>
                      • <span class="text-green-600 font-medium">Remote</span>
                    <% end %>
                  </p>
                </div>
              </div>

              <p class="mt-3 text-gray-700 line-clamp-3">
                <%= truncate(strip_tags(job.description), length: 180) %>
              </p>

              <div class="mt-4 flex flex-wrap gap-2">
                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-indigo-100 text-indigo-700">
                  <%= job.employment_type.humanize %>
                </span>
                <% if job.salary_range %>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-700">
                    <%= job.salary_range %>
                  </span>
                <% end %>
                <% job.skills.limit(4).each do |skill| %>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-700">
                    <%= skill.name %>
                  </span>
                <% end %>
                <% if job.skills.count > 4 %>
                  <span class="text-xs text-gray-500">+<%= job.skills.count - 4 %> more</span>
                <% end %>
              </div>
            </div>

            <!-- Right: Actions -->
            <div class="flex flex-col items-end space-y-3">
              <span class="text-xs text-gray-500">
                Posted <%= time_ago_in_words(job.published_at) %> ago
              </span>

              <div class="flex items-center space-x-2">
                <% if user_signed_in? && current_user.job_seeker? %>
                  <% if current_user.bookmarks.exists?(job: job) %>
                    <%= button_to unbookmark_job_path(job), method: :delete, class: "p-2 text-red-600 hover:text-red-700" do %>
                      ⭐
                    <% end %>
                  <% else %>
                    <%= button_to bookmark_job_path(job), method: :post, class: "p-2 text-gray-400 hover:text-red-600" do %>
                      ☆
                    <% end %>
                  <% end %>
                <% end %>

                <%= link_to "View Details", job_path(job),
                    class: "px-3 py-2 border border-gray-300 text-sm rounded-xl bg-white text-gray-700 hover:bg-gray-50 shadow-sm" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if @jobs.empty? %>
        <div class="text-center py-12">
          <p class="text-gray-600">No jobs found. Try adjusting your filters.</p>
          <%= link_to "View All Jobs", jobs_path,
              class: "mt-4 inline-block bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-xl shadow-lg transition" %>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="mt-10 flex justify-center">
      <%= paginate @jobs if respond_to?(:paginate) %>
    </div>
  </section>
</div>
