<section class="page-hero relative">
  <span class="page-kicker">Job search</span>
  <h1 class="page-title">A cleaner way to scan opportunities.</h1>
  <p class="page-subtitle">Use focused filters, compensation hints, and quick bookmarking without losing context.</p>
</section>

<section class="section-card mb-8">
  <%= form_with url: jobs_path, method: :get, local: true, class: "grid gap-4 lg:grid-cols-12" do |f| %>
    <div class="lg:col-span-4">
      <%= f.label :search, "Search roles", class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.text_field :search, value: params[:search], placeholder: "Job title, company, or keyword" %>
    </div>

    <div class="lg:col-span-3">
      <%= f.label :location, class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.text_field :location, value: params[:location], placeholder: "City or region" %>
    </div>

    <div class="lg:col-span-2">
      <%= f.label :employment_type, "Type", class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.select :employment_type, @employment_types, { prompt: "Any type", selected: params[:employment_type] } %>
    </div>

    <div class="lg:col-span-2">
      <%= f.label :salary_min, "Min salary", class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.number_field :salary_min, value: params[:salary_min], placeholder: "50000" %>
    </div>

    <div class="lg:col-span-1 flex items-end">
      <%= f.submit "Search", class: "btn-primary w-full" %>
    </div>

    <div class="lg:col-span-3">
      <%= f.label :industry, class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.select :industry, @industries.map { |industry| [industry, industry] }, { prompt: "Any industry", selected: params[:industry] } %>
    </div>

    <div class="lg:col-span-3 flex items-center gap-3 pt-8">
      <%= f.check_box :remote, { checked: params[:remote] == "true" }, "true", "" %>
      <%= f.label :remote, "Remote only", class: "text-sm font-semibold text-slate-700" %>
    </div>

    <div class="lg:col-span-3">
      <label class="mb-2 block text-sm font-semibold text-slate-700">Sort by</label>
      <%= select_tag :sort,
          options_for_select([["Newest", "newest"], ["Oldest", "oldest"], ["Highest salary", "salary_high"], ["Lowest salary", "salary_low"], ["Company name", "company"]], params[:sort] || "newest"),
          onchange: "this.form.requestSubmit();" %>
    </div>

    <div class="lg:col-span-3 flex items-end justify-end">
      <%= link_to "Clear filters", jobs_path, class: "btn-secondary w-full md:w-auto" %>
    </div>
  <% end %>
</section>

<section class="mb-6 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
  <div>
    <span class="badge-pill badge-teal"><%= @jobs.total_count %> results</span>
    <h2 class="mt-3 text-2xl font-bold text-slate-900">Open positions matching your filters</h2>
  </div>
</section>

<section class="grid gap-5">
  <% @jobs.each do |job| %>
    <article class="section-card">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="flex flex-1 gap-4">
          <% if job.company.logo.attached? %>
            <%= image_tag job.company.logo, class: "h-16 w-16 rounded-2xl object-cover shadow-sm" %>
          <% else %>
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-teal-100 text-lg font-bold text-teal-700">
              <%= job.company.name.first.upcase %>
            </div>
          <% end %>

          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="text-2xl font-bold text-slate-900">
                <%= link_to job.title, job_path(job), class: "hover:text-teal-700" %>
              </h3>
              <span class="badge-pill badge-slate"><%= job.employment_type.humanize %></span>
              <% if job.is_remote %>
                <span class="badge-pill badge-emerald">Remote</span>
              <% end %>
            </div>

            <p class="mt-2 text-sm font-semibold text-slate-600"><%= job.company.name %> • <%= job.location %></p>
            <p class="mt-4 text-sm leading-7 text-slate-600"><%= truncate(strip_tags(job.description), length: 200) %></p>

            <div class="mt-4 flex flex-wrap gap-2">
              <% if job.salary_range.present? %>
                <span class="badge-pill badge-amber"><%= job.salary_range %></span>
              <% end %>
              <% job.skills.limit(5).each do |skill| %>
                <span class="badge-pill badge-blue"><%= skill.name %></span>
              <% end %>
              <% if job.skills.count > 5 %>
                <span class="badge-pill badge-slate">+<%= job.skills.count - 5 %> more</span>
              <% end %>
            </div>
          </div>
        </div>

        <div class="flex flex-col items-start gap-3 lg:items-end">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Posted <%= time_ago_in_words(job.published_at || job.created_at) %> ago</p>
          <div class="flex flex-wrap items-center gap-2">
            <% if user_signed_in? && current_user.job_seeker? %>
              <% if current_user.bookmarks.exists?(job: job) %>
                <%= button_to unbookmark_job_path(job), method: :delete, class: "btn-secondary" do %>
                  Saved
                <% end %>
              <% else %>
                <%= button_to bookmark_job_path(job), method: :post, class: "btn-ghost" do %>
                  Save
                <% end %>
              <% end %>
            <% end %>
            <%= link_to "View details", job_path(job), class: "btn-primary" %>
          </div>
        </div>
      </div>
    </article>
  <% end %>

  <% if @jobs.empty? %>
    <div class="ui-empty-state">
      <h3 class="text-lg font-semibold text-slate-900">No jobs matched this search</h3>
      <p class="mt-2">Try broadening the title, location, or salary filters.</p>
      <div class="mt-5">
        <%= link_to "Reset search", jobs_path, class: "btn-primary" %>
      </div>
    </div>
  <% end %>
</section>

<div class="mt-8">
  <%= paginate @jobs if respond_to?(:paginate) %>
</div>
