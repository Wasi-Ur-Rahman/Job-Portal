<div class="mb-6">
  <%= link_to jobs_path, class: "btn-ghost" do %>
    Back to jobs
  <% end %>
</div>

<section class="section-card mb-8">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_340px]">
    <div>
      <div class="flex flex-wrap items-start gap-4">
        <% if @job.company.logo.attached? %>
          <%= image_tag @job.company.logo, class: "h-20 w-20 rounded-3xl object-cover shadow-sm" %>
        <% else %>
          <div class="flex h-20 w-20 items-center justify-center rounded-3xl bg-teal-100 text-2xl font-bold text-teal-700">
            <%= @job.company.name.first.upcase %>
          </div>
        <% end %>

        <div class="flex-1">
          <div class="flex flex-wrap items-center gap-2">
            <span class="badge-pill badge-teal"><%= @job.employment_type.humanize %></span>
            <% if @job.is_remote %>
              <span class="badge-pill badge-emerald">Remote</span>
            <% end %>
            <% if @job.salary_range.present? %>
              <span class="badge-pill badge-amber"><%= @job.salary_range %></span>
            <% end %>
          </div>

          <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @job.title %></h1>
          <p class="mt-2 text-lg font-semibold text-slate-600"><%= @job.company.name %> • <%= @job.location %></p>
          <p class="mt-4 text-sm text-slate-500">
            Posted <%= time_ago_in_words(@job.published_at || @job.created_at) %> ago
            • <%= pluralize(@job.views_count, "view") %>
            • <%= pluralize(@job.applications_count, "application") %>
          </p>
        </div>
      </div>

      <% if @job.skills.any? %>
        <div class="mt-6 flex flex-wrap gap-2">
          <% @job.skills.each do |skill| %>
            <span class="badge-pill badge-blue"><%= skill.name %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <aside class="section-card-muted h-fit">
      <h2 class="text-lg font-bold text-slate-900">Ready to move?</h2>
      <p class="mt-2 text-sm leading-7 text-slate-500">Keep the decision path short: save it, apply now, or sign in to track your status.</p>

      <div class="mt-5 grid gap-3">
        <% if user_signed_in? && current_user.job_seeker? %>
          <% if @has_applied %>
            <div class="rounded-2xl bg-emerald-50 p-4 text-sm text-emerald-800">
              <p class="font-semibold">Application submitted</p>
              <p class="mt-1"><%= link_to "View your application", application_path(@application), class: "underline" %></p>
            </div>
          <% else %>
            <%= link_to "Apply now", apply_job_path(@job), class: "btn-primary w-full" %>
          <% end %>

          <% if @is_bookmarked %>
            <%= button_to unbookmark_job_path(@job), method: :delete, class: "btn-secondary w-full" do %>
              Remove bookmark
            <% end %>
          <% else %>
            <%= button_to bookmark_job_path(@job), method: :post, class: "btn-ghost w-full" do %>
              Save for later
            <% end %>
          <% end %>
        <% elsif user_signed_in? %>
          <div class="rounded-2xl bg-slate-100 p-4 text-sm text-slate-600">
            Only job seekers can apply to roles.
          </div>
        <% else %>
          <%= link_to "Create account", new_user_registration_path, class: "btn-primary w-full" %>
          <%= link_to "Sign in", new_user_session_path, class: "btn-secondary w-full" %>
        <% end %>
      </div>

      <dl class="mt-6 space-y-3 border-t border-slate-200 pt-5 text-sm">
        <div class="flex items-center justify-between gap-3">
          <dt class="text-slate-500">Application deadline</dt>
          <dd class="font-semibold text-slate-800"><%= @job.application_deadline&.strftime("%b %d, %Y") || "Open until filled" %></dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="text-slate-500">Expires</dt>
          <dd class="font-semibold text-slate-800"><%= @job.expires_at&.strftime("%b %d, %Y") || "Not set" %></dd>
        </div>
      </dl>
    </aside>
  </div>
</section>

<div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_340px]">
  <div class="space-y-8">
    <section class="section-card">
      <h2 class="text-2xl font-bold text-slate-900">Role overview</h2>
      <div class="prose mt-5 max-w-none">
        <%= simple_format(@job.description) %>
      </div>
    </section>

    <section class="section-card">
      <h2 class="text-2xl font-bold text-slate-900">About <%= @job.company.name %></h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        <div class="section-card-muted">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Industry</p>
          <p class="mt-2 text-lg font-semibold text-slate-900"><%= @job.company.industry.presence || "Not provided" %></p>
        </div>
        <div class="section-card-muted">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Company size</p>
          <p class="mt-2 text-lg font-semibold text-slate-900"><%= @job.company.size.present? ? "#{@job.company.size} employees" : "Not provided" %></p>
        </div>
        <div class="section-card-muted">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Location</p>
          <p class="mt-2 text-lg font-semibold text-slate-900"><%= @job.company.location.presence || "Not provided" %></p>
        </div>
        <div class="section-card-muted">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Website</p>
          <p class="mt-2 text-lg font-semibold text-slate-900">
            <% if @job.company.website.present? %>
              <%= link_to @job.company.website, @job.company.website, target: "_blank", class: "text-teal-700 hover:text-teal-800" %>
            <% else %>
              Not provided
            <% end %>
          </p>
        </div>
      </div>

      <% if @job.company.description.present? %>
        <div class="prose mt-6 max-w-none">
          <%= simple_format(@job.company.description) %>
        </div>
      <% end %>
    </section>
  </div>

  <aside class="space-y-6">
    <% if @similar_jobs.any? %>
      <section class="section-card">
        <h3 class="text-lg font-bold text-slate-900">Similar roles</h3>
        <div class="mt-4 space-y-4">
          <% @similar_jobs.each do |job| %>
            <div class="border-t border-slate-200 pt-4 first:border-0 first:pt-0">
              <h4 class="text-base font-semibold text-slate-900">
                <%= link_to job.title, job_path(job), class: "hover:text-teal-700" %>
              </h4>
              <p class="mt-1 text-sm text-slate-500"><%= job.company.name %> • <%= job.location %></p>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @related_jobs.any? %>
      <section class="section-card">
        <h3 class="text-lg font-bold text-slate-900">More at <%= @job.company.name %></h3>
        <div class="mt-4 space-y-4">
          <% @related_jobs.each do |job| %>
            <div class="border-t border-slate-200 pt-4 first:border-0 first:pt-0">
              <h4 class="text-base font-semibold text-slate-900">
                <%= link_to job.title, job_path(job), class: "hover:text-teal-700" %>
              </h4>
              <p class="mt-1 text-sm text-slate-500"><%= job.location %> • <%= job.employment_type.humanize %></p>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </aside>
</div>
