<div class="bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li>
          <%= link_to jobs_path, class: "text-indigo-600 hover:text-indigo-900" do %>
            ← Back to Jobs
          <% end %>
        </li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Job Header -->
        <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center mb-4">
                <% if @job.company.logo.attached? %>
                  <%= image_tag @job.company.logo, class: "h-16 w-16 rounded-lg object-cover mr-4" %>
                <% else %>
                  <div class="h-16 w-16 bg-gray-200 rounded-lg flex items-center justify-center mr-4">
                    <span class="text-lg font-medium text-gray-600"><%= @job.company.name.first.upcase %></span>
                  </div>
                <% end %>
                
                <div>
                  <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @job.title %></h1>
                  <p class="text-lg text-gray-600">
                    <%= link_to @job.company.name, "#", class: "hover:text-indigo-600" %> • 
                    <%= @job.location %>
                    <% if @job.is_remote %>
                      • <span class="text-green-600 font-medium">Remote</span>
                    <% end %>
                  </p>
                  <p class="text-sm text-gray-500 mt-1">
                    Posted <%= time_ago_in_words(@job.published_at) %> ago • 
                    <%= pluralize(@job.views_count, 'view') %> • 
                    <%= pluralize(@job.applications_count, 'application') %>
                  </p>
                </div>
              </div>
              
              <!-- Job Meta Info -->
              <div class="flex flex-wrap gap-4 mb-6">
                <div class="flex items-center">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                    <%= @job.employment_type.humanize %>
                  </span>
                </div>
                
                <% if @job.salary_range %>
                  <div class="flex items-center">
                    <svg class="w-4 h-4 text-gray-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700"><%= @job.salary_range %></span>
                  </div>
                <% end %>
                
                <% if @job.application_deadline %>
                  <div class="flex items-center">
                    <svg class="w-4 h-4 text-gray-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Apply by <%= @job.application_deadline.strftime('%B %d, %Y') %></span>
                  </div>
                <% end %>
              </div>

              <!-- Skills -->
              <% if @job.skills.any? %>
                <div class="mb-6">
                  <h3 class="text-sm font-medium text-gray-900 mb-2">Required Skills</h3>
                  <div class="flex flex-wrap gap-2">
                    <% @job.skills.each do |skill| %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                        <%= skill.name %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
            
            <!-- Action Buttons -->
            <div class="ml-6 flex flex-col space-y-3">
              <% if user_signed_in? && current_user.job_seeker? %>
                <% if @has_applied %>
                  <div class="text-center">
                    <span class="inline-flex items-center px-4 py-2 border border-green-300 rounded-md text-sm font-medium text-green-700 bg-green-50">
                      ✓ Applied
                    </span>
                    <p class="text-xs text-gray-500 mt-1">
                      <%= link_to "View Application", application_path(@application), class: "hover:text-indigo-600" %>
                    </p>
                  </div>
                <% else %>
                  <%= link_to apply_job_path(@job), 
                      class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                    Apply Now
                  <% end %>
                <% end %>
                
                <% if @is_bookmarked %>
                  <%= button_to unbookmark_job_path(@job), method: :delete,
                      class: "inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-red-50 hover:bg-red-100" do %>
                    ⭐
                    Bookmarked
                  <% end %>
                <% else %>
                  <%= button_to bookmark_job_path(@job), method: :post,
                      class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
                    ☆
                    Bookmark
                  <% end %>
                <% end %>
              <% elsif user_signed_in? %>
                <p class="text-sm text-gray-500 bg-gray-50 p-3 rounded-md">
                  Only job seekers can apply for jobs.
                </p>
              <% else %>
                <div class="space-y-2">
                  <%= link_to new_user_registration_path, 
                      class: "block w-full text-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
                    Sign Up to Apply
                  <% end %>
                  <%= link_to new_user_session_path, 
                      class: "block w-full text-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
                    Sign In
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Job Description -->
        <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Job Description</h2>
          <div class="prose max-w-none">
            <%= simple_format(@job.description) %>
          </div>
        </div>

        <!-- Company Information -->
        <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
          <h2 class="text-xl font-bold text-gray-900 mb-4">About <%= @job.company.name %></h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <h3 class="text-sm font-medium text-gray-500">Industry</h3>
              <p class="text-gray-900"><%= @job.company.industry %></p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Company Size</h3>
              <p class="text-gray-900"><%= @job.company.size %> employees</p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Location</h3>
              <p class="text-gray-900"><%= @job.company.location %></p>
            </div>
            <% if @job.company.website.present? %>
              <div>
                <h3 class="text-sm font-medium text-gray-500">Website</h3>
                <p class="text-gray-900">
                  <%= link_to @job.company.website, @job.company.website, 
                      target: '_blank', 
                      class: "text-indigo-600 hover:text-indigo-900" %>
                </p>
              </div>
            <% end %>
          </div>
          
          <% if @job.company.description.present? %>
            <div class="prose max-w-none">
              <%= simple_format(@job.company.description) %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <!-- Similar Jobs -->
        <% if @similar_jobs.any? %>
          <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Similar Jobs</h3>
            <div class="space-y-4">
              <% @similar_jobs.each do |job| %>
                <div class="border-b border-gray-200 pb-4 last:border-b-0 last:pb-0">
                  <h4 class="text-sm font-medium text-gray-900 hover:text-indigo-600">
                    <%= link_to job.title, job_path(job) %>
                  </h4>
                  <p class="text-xs text-gray-500">
                    <%= job.company.name %> • <%= job.location %>
                  </p>
                  <p class="text-xs text-gray-600 mt-1">
                    <%= truncate(strip_tags(job.description), length: 100) %>
                  </p>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Related Jobs from Company -->
        <% if @related_jobs.any? %>
          <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">
              More jobs at <%= @job.company.name %>
            </h3>
            <div class="space-y-4">
              <% @related_jobs.each do |job| %>
                <div class="border-b border-gray-200 pb-4 last:border-b-0 last:pb-0">
                  <h4 class="text-sm font-medium text-gray-900 hover:text-indigo-600">
                    <%= link_to job.title, job_path(job) %>
                  </h4>
                  <p class="text-xs text-gray-500">
                    <%= job.location %> • <%= job.employment_type.humanize %>
                  </p>
                  <% if job.salary_range %>
                    <p class="text-xs text-gray-600"><%= job.salary_range %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Job Stats -->
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Job Statistics</h3>
          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-sm text-gray-500">Views</span>
              <span class="text-sm font-medium text-gray-900"><%= @job.views_count %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-500">Applications</span>
              <span class="text-sm font-medium text-gray-900"><%= @job.applications_count %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-500">Posted</span>
              <span class="text-sm font-medium text-gray-900">
                <%= @job.published_at.strftime('%b %d, %Y') %>
              </span>
            </div>
            <% if @job.expires_at %>
              <div class="flex justify-between">
                <span class="text-sm text-gray-500">Expires</span>
                <span class="text-sm font-medium text-gray-900">
                  <%= @job.expires_at.strftime('%b %d, %Y') %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>