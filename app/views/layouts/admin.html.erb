<!DOCTYPE html>
<html>
  <head>
    <title>Job Portal - Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <%= turbo_stream_from notification_stream_name(current_user) %>
    <% end %>

    <nav class="topbar" data-controller="mobile-nav">
      <div class="topbar-shell">
        <div class="topbar-row">
          <div class="flex items-center gap-3">
            <%= link_to admin_dashboard_path, class: "topbar-brand" do %>
              <span class="topbar-brand-mark">AD</span>
              <span>Admin Console</span>
            <% end %>

            <div class="topbar-nav">
              <%= link_to "Dashboard", admin_dashboard_path, class: "topbar-link #{'active' if current_page?(admin_dashboard_path)}" %>
              <%= link_to "Users", admin_users_path, class: "topbar-link #{'active' if controller_name == 'users'}" %>
              <%= link_to "Companies", admin_companies_path, class: "topbar-link #{'active' if controller_name == 'companies'}" %>
              <%= link_to "Jobs", admin_jobs_path, class: "topbar-link #{'active' if controller_name == 'jobs'}" %>
              <%= link_to "Requests", admin_recruiter_requests_path, class: "topbar-link #{'active' if controller_name == 'recruiter_requests'}" %>
              <%= link_to "Analytics", admin_analytics_path, class: "topbar-link #{'active' if controller_name == 'analytics'}" %>
            </div>
          </div>

          <div class="topbar-actions">
            <div class="topbar-meta">
              <div class="text-right">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Administrator</p>
                <p class="text-sm font-semibold text-slate-800"><%= current_user.full_name %></p>
              </div>
              <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn-secondary" %>
            </div>
          </div>

          <button type="button" class="topbar-mobile-toggle" data-mobile-nav-target="button" data-action="mobile-nav#toggle" aria-expanded="false" aria-label="Toggle navigation">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M4 12h16M4 17h16" />
            </svg>
          </button>
        </div>

        <div class="topbar-mobile-panel hidden" data-mobile-nav-target="panel">
          <div class="topbar-mobile-stack">
            <%= link_to "Dashboard", admin_dashboard_path, class: "topbar-link #{'active' if current_page?(admin_dashboard_path)}", data: { action: "mobile-nav#close" } %>
            <%= link_to "Users", admin_users_path, class: "topbar-link #{'active' if controller_name == 'users'}", data: { action: "mobile-nav#close" } %>
            <%= link_to "Companies", admin_companies_path, class: "topbar-link #{'active' if controller_name == 'companies'}", data: { action: "mobile-nav#close" } %>
            <%= link_to "Jobs", admin_jobs_path, class: "topbar-link #{'active' if controller_name == 'jobs'}", data: { action: "mobile-nav#close" } %>
            <%= link_to "Requests", admin_recruiter_requests_path, class: "topbar-link #{'active' if controller_name == 'recruiter_requests'}", data: { action: "mobile-nav#close" } %>
            <%= link_to "Analytics", admin_analytics_path, class: "topbar-link #{'active' if controller_name == 'analytics'}", data: { action: "mobile-nav#close" } %>
            <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete, action: "mobile-nav#close" }, class: "btn-primary w-full" %>
          </div>
        </div>
      </div>
    </nav>

    <main class="app-shell">
      <% if notice || alert %>
        <div class="flash-stack">
          <% if notice %>
            <div class="flash-banner notice"><div><p class="font-semibold">Success</p><p><%= notice %></p></div></div>
          <% end %>
          <% if alert %>
            <div class="flash-banner alert"><div><p class="font-semibold">Attention</p><p><%= alert %></p></div></div>
          <% end %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
