<!DOCTYPE html>
<html>
  <head>
    <title>Job Portal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <%= turbo_stream_from notification_stream_name(current_user) %>
    <% end %>

    <% unless recruiter_onboarding_page? %>
      <nav class="topbar" data-controller="mobile-nav">
        <div class="topbar-shell">
          <div class="topbar-row">
            <div class="flex items-center gap-3">
              <%= link_to root_path, class: "topbar-brand" do %>
                <span class="topbar-brand-mark">JP</span>
                <span>Job Portal</span>
              <% end %>

              <div class="topbar-nav">
                <%= link_to "Home", root_path, class: "topbar-link #{'active' if current_page?(root_path)}" %>
                <%= link_to "Browse Jobs", jobs_path, class: "topbar-link #{'active' if controller_name == 'jobs'}" %>
                <% if user_signed_in? && current_user.job_seeker? %>
                  <%= link_to "Applications", applications_path, class: "topbar-link #{'active' if controller_name == 'applications'}" %>
                  <%= link_to "Bookmarks", bookmarks_path, class: "topbar-link #{'active' if controller_name == 'bookmarks'}" %>
                <% end %>
                <% if user_signed_in? %>
                  <%= link_to "Notifications", notifications_path, class: "topbar-link #{'active' if controller_name == 'notifications'}" %>
                <% end %>
              </div>
            </div>

            <div class="topbar-actions">
              <%= render "shared/notification_badge", user: current_user %>
              <% if user_signed_in? %>
                <div class="topbar-meta">
                  <div class="text-right">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Account</p>
                    <p class="text-sm font-semibold text-slate-800"><%= current_user.first_name %></p>
                  </div>
                  <%= link_to "Profile", profile_path, class: "topbar-link #{'active' if controller_name == 'users'}" %>
                  <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn-secondary" %>
                </div>
              <% else %>
                <%= link_to "Sign In", new_user_session_path, class: "btn-secondary" %>
                <%= link_to "Create Account", new_user_registration_path, class: "btn-primary" %>
              <% end %>
            </div>

            <button type="button" class="topbar-mobile-toggle" data-mobile-nav-target="button" data-action="mobile-nav#toggle" aria-expanded="false" aria-label="Toggle navigation">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M4 12h16M4 17h16" />
              </svg>
            </button>
          </div>

          <div class="topbar-mobile-panel hidden" data-mobile-nav-target="panel">
            <div class="topbar-mobile-stack">
              <%= link_to "Home", root_path, class: "topbar-link #{'active' if current_page?(root_path)}", data: { action: "mobile-nav#close" } %>
              <%= link_to "Browse Jobs", jobs_path, class: "topbar-link #{'active' if controller_name == 'jobs'}", data: { action: "mobile-nav#close" } %>
              <% if user_signed_in? && current_user.job_seeker? %>
                <%= link_to "Applications", applications_path, class: "topbar-link #{'active' if controller_name == 'applications'}", data: { action: "mobile-nav#close" } %>
                <%= link_to "Bookmarks", bookmarks_path, class: "topbar-link #{'active' if controller_name == 'bookmarks'}", data: { action: "mobile-nav#close" } %>
              <% end %>
              <% if user_signed_in? %>
                <%= link_to "Notifications", notifications_path, class: "topbar-link #{'active' if controller_name == 'notifications'}", data: { action: "mobile-nav#close" } %>
                <%= link_to "Profile", profile_path, class: "btn-secondary w-full", data: { action: "mobile-nav#close" } %>
                <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: "Are you sure?", action: "mobile-nav#close" }, class: "btn-primary w-full" %>
              <% else %>
                <%= link_to "Sign In", new_user_session_path, class: "btn-secondary w-full", data: { action: "mobile-nav#close" } %>
                <%= link_to "Create Account", new_user_registration_path, class: "btn-primary w-full", data: { action: "mobile-nav#close" } %>
              <% end %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="app-shell">
      <% if notice || alert %>
        <div class="flash-stack">
          <% if notice %>
            <div class="flash-banner notice">
              <svg class="mt-0.5 h-5 w-5 flex-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <p class="font-semibold">Success</p>
                <p><%= notice %></p>
              </div>
            </div>
          <% end %>

          <% if alert %>
            <div class="flash-banner alert">
              <svg class="mt-0.5 h-5 w-5 flex-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 9v4m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z" />
              </svg>
              <div>
                <p class="font-semibold">Attention</p>
                <p><%= alert %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
