<!DOCTYPE html>
<html>
  <head>
    <title>Job Portal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- Navigation -->
    <% unless recruiter_onboarding_page? %>
      <nav class="bg-white shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex">
              <div class="flex-shrink-0 flex items-center">
                <%= link_to "Job Portal", root_path, class: "text-xl font-bold text-indigo-600" %>
              </div>
              
              <% if user_signed_in? %>
                <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
                  <!-- Show only for job seekers -->
                  <% if current_user.job_seeker? %>
                    <%= link_to "Browse Jobs", jobs_path, 
                        class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>
                    
                    <%= link_to "My Applications", applications_path, 
                        class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>
                    
                    <%= link_to "Bookmarks", bookmarks_path, 
                        class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="hidden sm:ml-6 sm:flex sm:items-center">
            <%= render 'shared/notification_badge' %>
              <% if user_signed_in? %>
                <div class="ml-3 relative">
                  <span class="text-gray-700 text-sm mr-4">Hello, <%= current_user.first_name %></span>
                  <%= link_to "Profile", profile_path, class: "text-gray-500 hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium" %>
                  <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' },
                      class: "text-gray-500 hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium" %>
                </div>
              <% else %>
                <%= link_to "Sign In", new_user_session_path, class: "text-gray-500 hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium" %>
                <%= link_to "Sign Up", new_user_registration_path, class: "ml-3 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
              <% end %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
        <%= notice %>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <%= alert %>
      </div>
    <% end %>
    
    <main class="<%= recruiter_onboarding_page? ? '' : 'container mx-auto px-4' %>">
      <%= yield %>
    </main>
  </body>
</html>