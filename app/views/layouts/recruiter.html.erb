<!DOCTYPE html>
<html>
  <head>
    <title>Job Portal - Recruiter</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to recruiter_dashboard_path, class: "text-xl font-bold text-indigo-600" do %>
                Job Portal
              <% end %>
            </div>
            <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
              <%= link_to "Dashboard", recruiter_dashboard_path, 
                  class: "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{'border-indigo-500 text-gray-900' if current_page?(recruiter_dashboard_path)}" %>
              
              <%= link_to "Jobs", recruiter_jobs_path, 
                  class: "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{'border-indigo-500 text-gray-900' if controller_name == 'jobs'}" %>
              
              <%= link_to "Applications", recruiter_applications_path, 
                  class: "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{'border-indigo-500 text-gray-900' if controller_name == 'applications'}" %>

              <!-- Show Team Management only for managers -->
              <% if current_user.can_manage_company?(current_company) %>
                <%= link_to "Team", recruiter_team_index_path, 
                    class: "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{'border-indigo-500 text-gray-900' if controller_name == 'team'}" %>
                <%= link_to "Company", edit_recruiter_company_path(current_company), 
                  class: "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" %>
              <% end %>
            </div>
          </div>
          
          <div class="hidden sm:ml-6 sm:flex sm:items-center">
          <%= render 'shared/notification_badge' %>
            <!-- Company info -->
            <div class="ml-3 flex items-center mr-4">
              <% if current_company&.logo&.attached? %>
                <%= image_tag current_company.logo, class: "h-8 w-8 rounded-full mr-2" %>
              <% end %>
              <span class="text-sm text-gray-700"><%= current_company&.name %></span>
            </div>

            <!-- Profile dropdown -->
            <div class="ml-3 relative">
              <div class="flex items-center text-sm text-gray-700">
                <span class="mr-4">Hello, <%= current_user.first_name %></span>
                <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete },
                    class: "text-gray-500 hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-50 border-l-4 border-green-400 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-green-700"><%= notice %></p>
          </div>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-red-700"><%= alert %></p>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>