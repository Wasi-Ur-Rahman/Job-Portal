<article id="<%= dom_id(notification) %>" class="section-card-muted <%= 'ring-2 ring-teal-200' if notification.unread? %>">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div class="flex-1">
      <div class="flex flex-wrap items-center gap-2">
        <% if notification.unread? %>
          <span class="badge-pill badge-teal">Unread</span>
        <% end %>
        <h3 class="text-lg font-bold text-slate-900"><%= notification.title %></h3>
      </div>
      <p class="mt-3 text-sm leading-7 text-slate-600"><%= notification.content %></p>
    </div>

    <div class="text-sm text-slate-400">
      <%= time_ago_in_words(notification.created_at) %> ago
    </div>
  </div>

  <div class="mt-5 flex flex-wrap gap-2">
    <%= link_to "Open", notification_path(notification), class: "btn-ghost" %>
    <% if notification.unread? %>
      <%= button_to mark_as_read_notification_path(notification), method: :post, form: { data: { turbo_stream: true } }, class: "btn-secondary" do %>
        Mark as read
      <% end %>
    <% end %>
    <%= button_to notification_path(notification), method: :delete, form: { data: { turbo_stream: true } }, data: { turbo_confirm: "Delete this notification?" }, class: "btn-danger" do %>
      Delete
    <% end %>
  </div>
</article>
