<section class="page-hero relative">
  <span class="page-kicker">Candidate review</span>
  <h1 class="page-title">Manage applicants with more signal and less noise.</h1>
  <p class="page-subtitle">Use status filters, job filters, and a tighter list layout to move candidates through the funnel faster.</p>
</section>

<section class="mb-8 stat-grid">
  <% { "Total" => @stats[:total], "Applied" => @stats[:applied], "Viewed" => @stats[:viewed], "Shortlisted" => @stats[:shortlisted], "Rejected" => @stats[:rejected], "Hired" => @stats[:hired] }.each do |label, value| %>
    <div class="stat-card">
      <p class="stat-label"><%= label %></p>
      <p class="stat-value"><%= value %></p>
      <p class="stat-meta">Candidates in this stage.</p>
    </div>
  <% end %>
</section>

<section class="section-card mb-8">
  <%= form_with url: recruiter_applications_path, method: :get, local: true, class: "grid gap-4 md:grid-cols-3" do |f| %>
    <div>
      <%= f.label :status, "Status", class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.select :status, [["All statuses", ""], ["Applied", "applied"], ["Viewed", "viewed"], ["Shortlisted", "shortlisted"], ["Rejected", "rejected"], ["Hired", "hired"]], { selected: params[:status] } %>
    </div>
    <div>
      <%= f.label :job_id, "Job", class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.select :job_id, options_for_select([["All jobs", ""]] + @company_jobs, params[:job_id]) %>
    </div>
    <div class="flex items-end">
      <%= f.submit "Apply filters", class: "btn-primary w-full" %>
    </div>
  <% end %>
</section>

<section class="space-y-5">
  <% if @applications.any? %>
    <% @applications.each do |application| %>
      <article class="section-card">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="text-2xl font-bold text-slate-900">
                <%= link_to application.user.full_name, recruiter_application_path(application), class: "hover:text-teal-700" %>
              </h2>
              <span class="badge-pill badge-blue"><%= application.status.humanize %></span>
            </div>
            <p class="mt-2 text-sm text-slate-500"><%= application.user.email %></p>
            <p class="mt-2 text-sm font-semibold text-slate-600">Applied for <%= application.job.title %></p>
            <p class="mt-3 text-xs uppercase tracking-[0.18em] text-slate-400">Applied <%= time_ago_in_words(application.applied_at) %> ago</p>
          </div>
          <%= link_to "Open review", recruiter_application_path(application), class: "btn-primary" %>
        </div>
      </article>
    <% end %>

    <div class="mt-8">
      <%= paginate @applications if respond_to?(:paginate) %>
    </div>
  <% else %>
    <div class="ui-empty-state">
      <p>No applications match the current filters.</p>
    </div>
  <% end %>
</section>
