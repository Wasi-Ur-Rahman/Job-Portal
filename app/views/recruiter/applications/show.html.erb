<section class="section-card mb-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <span class="badge-pill badge-blue"><%= @application.status.humanize %></span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @application.user.full_name %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @application.job.title %></p>
      <p class="mt-3 text-sm text-slate-500">Applied <%= @application.applied_at.strftime("%B %d, %Y at %I:%M %p") %></p>
    </div>
    <%= link_to "Back to applications", recruiter_applications_path, class: "btn-secondary" %>
  </div>
</section>

<div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_320px]">
  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">Candidate profile</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <div class="section-card-muted">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Applicant</p>
        <p class="mt-2 text-lg font-semibold text-slate-900"><%= @application.user.full_name %></p>
        <p class="mt-1 text-sm text-slate-500"><%= @application.user.email %></p>
      </div>
      <div class="section-card-muted">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Location</p>
        <p class="mt-2 text-lg font-semibold text-slate-900"><%= @application.user.location.presence || "Not provided" %></p>
      </div>
      <div class="section-card-muted md:col-span-2">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Cover letter</p>
        <div class="prose mt-3 max-w-none">
          <%= simple_format(@application.cover_letter) %>
        </div>
      </div>
    </div>

    <div class="mt-8">
      <h3 class="text-xl font-bold text-slate-900">Resume</h3>
      <div class="mt-4 rounded-2xl bg-slate-50 p-4">
        <% if @application.resume.attached? %>
          <p class="text-sm font-semibold text-slate-800"><%= @application.resume.filename %></p>
          <p class="mt-1 text-sm text-slate-500"><%= number_to_human_size(@application.resume.byte_size) %></p>
          <div class="mt-4">
            <%= link_to "Download resume", rails_blob_path(@application.resume, disposition: "attachment"), class: "btn-primary" %>
          </div>
        <% elsif @application.user.resume.attached? %>
          <p class="text-sm font-semibold text-slate-800"><%= @application.user.resume.filename %> (profile resume)</p>
          <div class="mt-4">
            <%= link_to "Download resume", rails_blob_path(@application.user.resume, disposition: "attachment"), class: "btn-primary" %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">No resume uploaded.</p>
        <% end %>
      </div>
    </div>
  </section>

  <aside class="space-y-6">
    <section class="section-card-muted">
      <h2 class="text-lg font-bold text-slate-900">Application actions</h2>
      <div class="mt-4 grid gap-3">
        <%= link_to "Mark as viewed", recruiter_application_path(@application, application: { status: "viewed" }), data: { turbo_method: :patch }, class: "btn-secondary w-full" %>
        <%= link_to "Shortlist candidate", recruiter_application_path(@application, application: { status: "shortlisted" }), data: { turbo_method: :patch }, class: "btn-success w-full" %>
        <%= link_to "Reject application", recruiter_application_path(@application, application: { status: "rejected" }), data: { turbo_method: :patch, turbo_confirm: "Reject this application?" }, class: "btn-danger w-full" %>
        <%= link_to "Mark as hired", recruiter_application_path(@application, application: { status: "hired" }), data: { turbo_method: :patch, turbo_confirm: "Mark this applicant as hired?" }, class: "btn-primary w-full" %>
      </div>
    </section>
  </aside>
</div>
