<section class="page-hero relative">
  <span class="page-kicker">Company settings</span>
  <h1 class="page-title">Keep your hiring company profile sharp.</h1>
  <p class="page-subtitle">A complete profile creates more trust in your public job listings and helps candidates convert faster.</p>
</section>

<section class="section-card max-w-5xl mx-auto">
  <%= form_with model: @company, url: recruiter_company_path(@company), method: :patch, local: true, class: "space-y-8" do |f| %>
    <% if @company.errors.any? %>
      <div class="flash-banner alert">
        <div>
          <p class="font-semibold">Please review these fields</p>
          <ul class="mt-2 list-disc pl-5">
            <% @company.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="grid gap-8 lg:grid-cols-2">
      <div class="section-card-muted space-y-5">
        <div>
          <%= f.label :name, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.text_field :name, required: true %>
        </div>
        <div>
          <%= f.label :description, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.text_area :description, rows: 8 %>
        </div>
      </div>

      <div class="space-y-6">
        <div class="section-card-muted grid gap-4 md:grid-cols-2">
          <div>
            <%= f.label :location, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= f.text_field :location %>
          </div>
          <div>
            <%= f.label :website, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= f.url_field :website, placeholder: "https://" %>
          </div>
          <div>
            <%= f.label :industry, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= f.select :industry, ["Technology", "Healthcare", "Finance", "Education", "Retail", "Manufacturing", "Other"].map { |i| [i, i] }, { prompt: "Select industry" } %>
          </div>
          <div>
            <%= f.label :size, "Company size", class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= f.select :size, Company::SIZES.map { |size| [size, size] }, { prompt: "Select size" } %>
          </div>
        </div>

        <div class="section-card-muted">
          <%= f.label :logo, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <% if @company.logo.attached? %>
            <div class="mb-4">
              <%= image_tag @company.logo, class: "h-20 w-20 rounded-3xl object-cover shadow-sm" %>
            </div>
          <% end %>
          <%= f.file_field :logo, accept: "image/*" %>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-3 border-t border-slate-200 pt-6 sm:flex-row sm:justify-between">
      <%= link_to "Cancel", recruiter_company_path(@company), class: "btn-secondary" %>
      <%= f.submit "Update company", class: "btn-primary" %>
    </div>
  <% end %>
</section>
