<div class="max-w-4xl mx-auto py-8">
  <div class="mb-6">
    <%= link_to recruiter_dashboard_path, class: "text-indigo-600 hover:text-indigo-900" do %>
      ← Back to Dashboard
    <% end %>
  </div>

  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit Company Profile</h1>
      
      <%= form_with model: @company, url: recruiter_company_path(@company), method: :patch, local: true, class: "space-y-6" do |f| %>
        <% if @company.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-md p-4">
            <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
            <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
              <% @company.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, required: true, 
              class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_area :description, rows: 4,
              class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :location, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :location,
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>
          
          <div>
            <%= f.label :website, class: "block text-sm font-medium text-gray-700" %>
            <%= f.url_field :website, placeholder: "https://",
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :industry, class: "block text-sm font-medium text-gray-700" %>
            <%= f.select :industry, 
                ['Technology', 'Healthcare', 'Finance', 'Education', 'Retail', 'Manufacturing', 'Other'].map { |i| [i, i] },
                { prompt: 'Select Industry' },
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>
          
          <div>
            <%= f.label :size, "Company Size", class: "block text-sm font-medium text-gray-700" %>
            <%= f.select :size, Company::SIZES.map { |s| [s, s] },
                { prompt: 'Select Size' },
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>
        </div>

        <div>
          <%= f.label :logo, class: "block text-sm font-medium text-gray-700" %>
          <% if @company.logo.attached? %>
            <div class="mt-2 mb-3">
              <%= image_tag @company.logo, class: "h-20 w-20 rounded-lg object-cover" %>
              <p class="text-sm text-gray-500 mt-1">Current logo</p>
            </div>
          <% end %>
          <%= f.file_field :logo, accept: "image/*",
              class: "mt-1 block w-full text-sm text-gray-900 border border-gray-300 rounded-md cursor-pointer bg-gray-50 focus:outline-none" %>
          <p class="mt-1 text-sm text-gray-500">PNG, JPG up to 2MB</p>
        </div>

        <div class="flex justify-between pt-6 border-t border-gray-200">
          <%= link_to "Cancel", recruiter_dashboard_path, 
              class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
          
          <%= f.submit "Update Company", 
              class: "px-6 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
