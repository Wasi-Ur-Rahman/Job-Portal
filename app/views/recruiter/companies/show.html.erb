<section class="section-card">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <span class="badge-pill badge-teal">Company profile</span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @company.name %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @company.location %> • <%= @company.industry %></p>
    </div>
    <% if current_user.can_manage_company?(@company) %>
      <%= link_to "Edit company", edit_recruiter_company_path(@company), class: "btn-primary" %>
    <% end %>
  </div>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    <div class="section-card-muted md:col-span-2">
      <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Description</p>
      <div class="prose mt-3 max-w-none">
        <%= simple_format(@company.description.presence || "No company description yet.") %>
      </div>
    </div>
    <div class="section-card-muted">
      <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Website</p>
      <p class="mt-2 text-lg font-semibold text-slate-900">
        <% if @company.website.present? %>
          <%= link_to @company.website, @company.website, target: "_blank", class: "text-teal-700 hover:text-teal-800" %>
        <% else %>
          Not provided
        <% end %>
      </p>
    </div>
    <div class="section-card-muted">
      <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Company size</p>
      <p class="mt-2 text-lg font-semibold text-slate-900"><%= @company.size %> employees</p>
    </div>
  </div>
</section>
