<section class="page-hero relative">
  <span class="page-kicker">Recruiter dashboard</span>
  <h1 class="page-title">Run hiring from one sharper workspace.</h1>
  <p class="page-subtitle">Track live jobs, recent applicants, and team requests without jumping between disconnected pages.</p>

  <div class="mt-8">
    <%= link_to "Post a new job", new_recruiter_job_path, class: "btn-primary" %>
  </div>
</section>

<section class="mb-8 stat-grid">
  <div class="stat-card">
    <p class="stat-label">Total jobs</p>
    <p class="stat-value"><%= @stats[:total_jobs] %></p>
    <p class="stat-meta"><%= @stats[:published_jobs] %> published, <%= @stats[:draft_jobs] %> draft.</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Applications</p>
    <p class="stat-value"><%= @stats[:total_applications] %></p>
    <p class="stat-meta"><%= @stats[:new_applications] %> new since your last pass.</p>
  </div>
  <% if @is_manager %>
    <div class="stat-card">
      <p class="stat-label">Recruiting team</p>
      <p class="stat-value"><%= @team_stats[:total_recruiters] %></p>
      <p class="stat-meta"><%= @team_stats[:pending_requests] %> request(s) waiting.</p>
    </div>
  <% end %>
  <div class="stat-card">
    <p class="stat-label">Draft jobs</p>
    <p class="stat-value"><%= @stats[:draft_jobs] %></p>
    <p class="stat-meta">Roles that still need review before publishing.</p>
  </div>
</section>

<div class="grid gap-8 lg:grid-cols-2">
  <section class="section-card">
    <div class="mb-5 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">Recent jobs</h2>
        <p class="mt-1 text-sm text-slate-500">The most recent roles in your hiring pipeline.</p>
      </div>
      <%= link_to "View all", recruiter_jobs_path, class: "btn-ghost" %>
    </div>

    <% if @recent_jobs.any? %>
      <div class="space-y-4">
        <% @recent_jobs.each do |job| %>
          <div class="section-card-muted">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-bold text-slate-900">
                  <%= link_to job.title, recruiter_job_path(job), class: "hover:text-teal-700" %>
                </h3>
                <p class="mt-2 text-sm text-slate-500"><%= job.location %> • <%= job.employment_type.humanize %> • <%= pluralize(job.applications_count, "application") %></p>
              </div>
              <span class="badge-pill <%= job.status == "published" ? "badge-emerald" : job.status == "closed" ? "badge-red" : "badge-slate" %>"><%= job.status.humanize %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="ui-empty-state">
        <p>No jobs posted yet.</p>
      </div>
    <% end %>
  </section>

  <section class="section-card">
    <div class="mb-5 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">Recent applications</h2>
        <p class="mt-1 text-sm text-slate-500">Fresh candidate activity across your jobs.</p>
      </div>
      <%= link_to "Review all", recruiter_applications_path, class: "btn-ghost" %>
    </div>

    <% if @recent_applications.any? %>
      <div class="space-y-4">
        <% @recent_applications.limit(5).each do |application| %>
          <div class="section-card-muted">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-bold text-slate-900">
                  <%= link_to application.user.full_name, recruiter_application_path(application), class: "hover:text-teal-700" %>
                </h3>
                <p class="mt-2 text-sm text-slate-500"><%= application.job.title %> • <%= time_ago_in_words(application.applied_at) %> ago</p>
              </div>
              <span class="badge-pill badge-blue"><%= application.status.humanize %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="ui-empty-state">
        <p>No applications received yet.</p>
      </div>
    <% end %>
  </section>
</div>

<% if @is_manager && @pending_team_requests.any? %>
  <section class="section-card mt-8">
    <div class="mb-5 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">Pending team requests</h2>
        <p class="mt-1 text-sm text-slate-500">Recruiters waiting to join your company.</p>
      </div>
      <%= link_to "Manage team", recruiter_team_index_path, class: "btn-secondary" %>
    </div>

    <div class="space-y-4">
      <% @pending_team_requests.each do |request| %>
        <div class="section-card-muted">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="text-lg font-bold text-slate-900"><%= request.user.full_name %></h3>
              <p class="mt-2 text-sm text-slate-500"><%= request.user.email %> • Requested <%= time_ago_in_words(request.created_at) %> ago</p>
            </div>
            <%= link_to "Review", recruiter_team_index_path, class: "btn-ghost" %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
