<%= form_with model: [:recruiter, job], local: true, class: "space-y-8" do |f| %>
  <% if job.errors.any? %>
    <div class="flash-banner alert">
      <div>
        <p class="font-semibold">Please review these fields</p>
        <ul class="mt-2 list-disc pl-5">
          <% job.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="grid gap-8 lg:grid-cols-2">
    <div class="section-card-muted space-y-5">
      <h2 class="text-xl font-bold text-slate-900">Role basics</h2>

      <div>
        <%= f.label :title, class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= f.text_field :title, required: true, placeholder: "Senior Software Engineer" %>
      </div>

      <div>
        <%= f.label :description, class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= f.text_area :description, rows: 12, required: true, placeholder: "Describe responsibilities, expectations, and what success looks like." %>
      </div>
    </div>

    <div class="space-y-6">
      <div class="section-card-muted grid gap-4 md:grid-cols-2">
        <div>
          <%= f.label :employment_type, "Employment type", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.select :employment_type, Job.employment_types.keys.map { |type| [type.humanize, type] }, { prompt: "Select type" } %>
        </div>
        <div>
          <%= f.label :location, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.text_field :location, placeholder: "San Francisco, CA" %>
        </div>
        <div>
          <%= f.label :salary_min, "Minimum salary", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.number_field :salary_min %>
        </div>
        <div>
          <%= f.label :salary_max, "Maximum salary", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.number_field :salary_max %>
        </div>
        <div>
          <%= f.label :currency, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.select :currency, [["USD", "USD"], ["EUR", "EUR"], ["GBP", "GBP"]], { selected: job.currency.presence || "USD" } %>
        </div>
        <div class="flex items-end gap-3 pb-2">
          <%= f.check_box :is_remote %>
          <%= f.label :is_remote, "Remote role", class: "text-sm font-semibold text-slate-700" %>
        </div>
        <div>
          <%= f.label :application_deadline, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.date_field :application_deadline %>
        </div>
        <div>
          <%= f.label :expires_at, "Expires on", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.date_field :expires_at %>
        </div>
      </div>

      <div class="section-card-muted" data-controller="tags" data-tags-param-name-value="skills[]">
        <h2 class="text-xl font-bold text-slate-900">Required skills</h2>
        <div data-tags-target="tagsContainer" class="mt-4 flex flex-wrap gap-2">
          <% job.skills.each do |skill| %>
            <span class="inline-flex items-center gap-2 rounded-full bg-teal-50 px-3 py-1 text-sm font-semibold text-teal-700">
              <%= skill.name %>
              <button type="button" data-action="tags#removeTag" class="font-bold text-teal-700">×</button>
              <input type="hidden" name="skills[]" value="<%= skill.name %>">
            </span>
          <% end %>
        </div>

        <div class="mt-4 flex gap-3">
          <input type="text" placeholder="Add a skill" data-action="keydown.enter->tags#addTag" data-tags-target="input">
          <button type="button" data-action="tags#addTag" class="btn-primary">Add</button>
        </div>
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-3 border-t border-slate-200 pt-6 sm:flex-row sm:justify-between">
    <%= link_to "Cancel", recruiter_jobs_path, class: "btn-secondary" %>
    <div class="flex flex-wrap gap-2">
      <% if job.new_record? %>
        <%= f.submit "Save draft", name: "draft", class: "btn-secondary" %>
        <%= f.submit "Publish job", name: "publish", value: "Submit", class: "btn-primary" %>
      <% else %>
        <%= f.submit "Update job", class: "btn-primary" %>
      <% end %>
    </div>
  </div>
<% end %>
