<div class="px-4 py-6 sm:px-0">
  <!-- Header -->
  <div class="md:flex md:items-center md:justify-between mb-8">
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        Job Management
      </h1>
      <p class="mt-1 text-sm text-gray-500">
        Manage all your job postings in one place
      </p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4">
      <%= link_to new_recruiter_job_path, 
          class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        Post New Job
      <% end %>
    </div>
  </div>

  <!-- Filter Tabs -->
  <div class="border-b border-gray-200 mb-6">
    <nav class="-mb-px flex space-x-8">
      <%= link_to recruiter_jobs_path, 
          class: "py-2 px-1 border-b-2 font-medium text-sm #{ params[:status].blank? ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }" do %>
        All Jobs <span class="bg-gray-100 text-gray-900 ml-2 py-0.5 px-2.5 rounded-full text-xs font-medium"><%= @stats[:all] %></span>
      <% end %>
      
      <%= link_to recruiter_jobs_path(status: 'published'), 
          class: "py-2 px-1 border-b-2 font-medium text-sm #{ params[:status] == 'published' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }" do %>
        Published <span class="bg-green-100 text-green-800 ml-2 py-0.5 px-2.5 rounded-full text-xs font-medium"><%= @stats[:published] %></span>
      <% end %>
      
      <%= link_to recruiter_jobs_path(status: 'draft'), 
          class: "py-2 px-1 border-b-2 font-medium text-sm #{ params[:status] == 'draft' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }" do %>
        Drafts <span class="bg-yellow-100 text-yellow-800 ml-2 py-0.5 px-2.5 rounded-full text-xs font-medium"><%= @stats[:draft] %></span>
      <% end %>
      
      <%= link_to recruiter_jobs_path(status: 'closed'), 
          class: "py-2 px-1 border-b-2 font-medium text-sm #{ params[:status] == 'closed' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }" do %>
        Closed <span class="bg-red-100 text-red-800 ml-2 py-0.5 px-2.5 rounded-full text-xs font-medium"><%= @stats[:closed] %></span>
      <% end %>
    </nav>
  </div>

  <!-- Jobs List -->
  <div class="bg-white shadow overflow-hidden sm:rounded-md">
    <% if @jobs.any? %>
      <ul class="divide-y divide-gray-200">
        <% @jobs.each do |job| %>
          <li>
            <div class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="flex items-center justify-between">
                    <div class="flex-1">
                      <h3 class="text-lg font-medium text-indigo-600 truncate">
                        <%= link_to job.title, recruiter_job_path(job), class: "hover:underline" %>
                      </h3>
                      <p class="text-sm text-gray-500">
                        <%= job.location %> • 
                        <%= job.employment_type.humanize %>
                        <% if job.salary_range %>
                          • <%= job.salary_range %>
                        <% end %>
                      </p>
                    </div>
                    <div class="ml-4 flex items-center space-x-4">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                                   <%= case job.status
                                       when 'draft' then 'bg-gray-100 text-gray-800'
                                       when 'published' then 'bg-green-100 text-green-800'
                                       when 'closed' then 'bg-red-100 text-red-800'
                                       end %>">
                        <%= job.status.humanize %>
                      </span>
                    </div>
                  </div>
                  
                  <div class="mt-2">
                    <p class="text-sm text-gray-700">
                      <%= truncate(strip_tags(job.description), length: 150) %>
                    </p>
                  </div>
                  
                  <div class="mt-4 flex items-center justify-between">
                    <div class="flex items-center text-sm text-gray-500 space-x-4">
                      <div class="flex items-center">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                          <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                        </svg>
                        <%= pluralize(job.views_count, 'view') %>
                      </div>
                      <div class="flex items-center">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <%= pluralize(job.applications_count, 'application') %>
                      </div>
                      <div class="flex items-center">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                        </svg>
                        Created <%= job.created_at.strftime('%b %d, %Y') %>
                      </div>
                    </div>
                    
                    <div class="flex items-center space-x-2">
                      <%= link_to "View", recruiter_job_path(job),
                          class: "text-indigo-600 hover:text-indigo-900 text-sm font-medium" %>
                      
                      <%= link_to "Edit", edit_recruiter_job_path(job),
                          class: "text-indigo-600 hover:text-indigo-900 text-sm font-medium" %>
                      
                      <% case job.status %>
                      <% when 'draft' %>
                        <%= button_to "Publish", toggle_status_recruiter_job_path(job), method: :patch,
                            class: "text-green-600 hover:text-green-900 text-sm font-medium" %>
                      <% when 'published' %>
                        <%= button_to "Close", toggle_status_recruiter_job_path(job), method: :patch,
                            class: "text-red-600 hover:text-red-900 text-sm font-medium" %>
                      <% when 'closed' %>
                        <%= button_to "Reopen", toggle_status_recruiter_job_path(job), method: :patch,
                            class: "text-green-600 hover:text-green-900 text-sm font-medium" %>
                      <% end %>
                      
                      <%= link_to "Delete", recruiter_job_path(job), method: :delete,
                          class: "text-red-600 hover:text-red-900 text-sm font-medium",
                          confirm: "Are you sure you want to delete this job?" %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
      
      <div class="px-4 py-3 bg-gray-50">
        <%= paginate @jobs if respond_to?(:paginate) %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m8 0V6a2 2 0 012 2v6a2 2 0 01-2 2H8a2 2 0 01-2-2V8a2 2 0 012-2V6"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No jobs found</h3>
        <p class="mt-1 text-sm text-gray-500">
          <% if params[:status].present? %>
            No jobs with status "<%= params[:status] %>" found.
          <% else %>
            Get started by posting your first job.
          <% end %>
        </p>
        <div class="mt-6">
          <%= link_to new_recruiter_job_path, 
              class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
            <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            Post New Job
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>