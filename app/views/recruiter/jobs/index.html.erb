<section class="page-hero relative">
  <span class="page-kicker">Job management</span>
  <h1 class="page-title">Control every role from one queue.</h1>
  <p class="page-subtitle">Draft, publish, close, and monitor performance without burying the signal in oversized tables.</p>

  <div class="mt-8">
    <%= link_to "Post new job", new_recruiter_job_path, class: "btn-primary" %>
  </div>
</section>

<section class="mb-8 stat-grid">
  <%= link_to recruiter_jobs_path, class: "stat-card block" do %>
    <p class="stat-label">All jobs</p>
    <p class="stat-value"><%= @stats[:all] %></p>
    <p class="stat-meta">See the full pipeline.</p>
  <% end %>
  <%= link_to recruiter_jobs_path(status: "published"), class: "stat-card block" do %>
    <p class="stat-label">Published</p>
    <p class="stat-value"><%= @stats[:published] %></p>
    <p class="stat-meta">Roles currently live.</p>
  <% end %>
  <%= link_to recruiter_jobs_path(status: "draft"), class: "stat-card block" do %>
    <p class="stat-label">Draft</p>
    <p class="stat-value"><%= @stats[:draft] %></p>
    <p class="stat-meta">Work still in progress.</p>
  <% end %>
  <%= link_to recruiter_jobs_path(status: "closed"), class: "stat-card block" do %>
    <p class="stat-label">Closed</p>
    <p class="stat-value"><%= @stats[:closed] %></p>
    <p class="stat-meta">No longer taking applicants.</p>
  <% end %>
</section>

<section class="space-y-5">
  <% if @jobs.any? %>
    <% @jobs.each do |job| %>
      <article class="section-card">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="text-2xl font-bold text-slate-900">
                <%= link_to job.title, recruiter_job_path(job), class: "hover:text-teal-700" %>
              </h2>
              <span class="badge-pill <%= job.status == "published" ? "badge-emerald" : job.status == "closed" ? "badge-red" : "badge-slate" %>"><%= job.status.humanize %></span>
            </div>
            <p class="mt-2 text-sm text-slate-500"><%= job.location %> • <%= job.employment_type.humanize %> <% if job.salary_range.present? %>• <%= job.salary_range %><% end %></p>
            <p class="mt-4 text-sm leading-7 text-slate-600"><%= truncate(strip_tags(job.description), length: 160) %></p>
            <div class="mt-4 flex flex-wrap gap-3 text-xs uppercase tracking-[0.18em] text-slate-400">
              <span><%= pluralize(job.views_count, "view") %></span>
              <span><%= pluralize(job.applications_count, "application") %></span>
              <span>Created <%= job.created_at.strftime("%b %d, %Y") %></span>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-2 lg:justify-end">
            <%= link_to "View", recruiter_job_path(job), class: "btn-secondary" %>
            <%= link_to "Edit", edit_recruiter_job_path(job), class: "btn-ghost" %>
            <% case job.status %>
            <% when "draft" %>
              <%= button_to "Publish", toggle_status_recruiter_job_path(job), method: :patch, class: "btn-success" %>
            <% when "published" %>
              <%= button_to "Close", toggle_status_recruiter_job_path(job), method: :patch, class: "btn-danger" %>
            <% when "closed" %>
              <%= button_to "Reopen", toggle_status_recruiter_job_path(job), method: :patch, class: "btn-success" %>
            <% end %>
            <%= link_to "Delete", recruiter_job_path(job), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this job?" }, class: "btn-secondary" %>
          </div>
        </div>
      </article>
    <% end %>

    <div class="mt-8">
      <%= paginate @jobs if respond_to?(:paginate) %>
    </div>
  <% else %>
    <div class="ui-empty-state">
      <h3 class="text-lg font-semibold text-slate-900">No jobs in this view</h3>
      <p class="mt-2">
        <% if params[:status].present? %>
          No roles currently marked <%= params[:status] %>.
        <% else %>
          Start by creating your first job posting.
        <% end %>
      </p>
      <div class="mt-5">
        <%= link_to "Post new job", new_recruiter_job_path, class: "btn-primary" %>
      </div>
    </div>
  <% end %>
</section>
