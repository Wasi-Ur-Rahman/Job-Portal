<div class="max-w-4xl mx-auto py-8">
  <div class="md:flex md:items-center md:justify-between mb-8">
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        Post New Job
      </h1>
      <p class="mt-1 text-sm text-gray-500">
        Create a new job posting for <%= current_company.name %>
      </p>
    </div>
  </div>

  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <%= form_with model: [@company, @job], url: recruiter_jobs_path, local: true, class: "space-y-6" do |f| %>
        <% if @job.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-md p-4">
            <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
            <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
              <% @job.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Basic Information -->
        <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
          <div class="sm:col-span-6">
            <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :title, required: true, 
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                placeholder: "e.g. Senior Software Engineer" %>
          </div>

          <div class="sm:col-span-6">
            <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_area :description, rows: 10, required: true,
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                placeholder: "Describe the role, responsibilities, requirements, and what makes this opportunity exciting..." %>
          </div>
        </div>

        <!-- Job Details -->
        <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
          <div class="sm:col-span-3">
            <%= f.label :employment_type, "Employment Type", class: "block text-sm font-medium text-gray-700" %>
            <%= f.select :employment_type,
                Job.employment_types.keys.map { |type| [type.humanize, type] },
                { prompt: 'Select type' },
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                required: true %>

          </div>

          <div class="sm:col-span-3">
            <%= f.label :location, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :location,
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                placeholder: "e.g. San Francisco, CA" %>
          </div>

          <div class="sm:col-span-2">
            <%= f.label :salary_min, "Minimum Salary", class: "block text-sm font-medium text-gray-700" %>
            <%= f.number_field :salary_min, 
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                placeholder: "50000" %>
          </div>

          <div class="sm:col-span-2">
            <%= f.label :salary_max, "Maximum Salary", class: "block text-sm font-medium text-gray-700" %>
            <%= f.number_field :salary_max,
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                placeholder: "80000" %>
          </div>

          <div class="sm:col-span-2">
            <%= f.label :currency, class: "block text-sm font-medium text-gray-700" %>
            <%= f.select :currency, [['USD', 'USD'], ['EUR', 'EUR'], ['GBP', 'GBP']], 
                { selected: 'USD' },
                { class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" } %>
          </div>

          <div class="sm:col-span-3">
            <%= f.label :application_deadline, class: "block text-sm font-medium text-gray-700" %>
            <%= f.date_field :application_deadline,
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>

          <div class="sm:col-span-3">
            <%= f.label :expires_at, "Job Expires On", class: "block text-sm font-medium text-gray-700" %>
            <%= f.date_field :expires_at,
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
          </div>

          <div class="sm:col-span-6">
            <div class="flex items-center">
              <%= f.check_box :is_remote, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
              <%= f.label :is_remote, "This is a remote position", class: "ml-2 block text-sm text-gray-900" %>
            </div>
          </div>
        </div>

        <!-- Skills -->
        <div>
          <label for="skills" class="block text-sm font-medium text-gray-700">Required Skills</label>
          <input type="text" id="skills" name="skills" 
                 class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500"
                 placeholder="e.g. Ruby, Rails, JavaScript, React (comma-separated)"
                 value="<%= @job.skills.map(&:name).join(', ') %>">
          <p class="mt-1 text-sm text-gray-500">Enter skills separated by commas</p>
        </div>

        <!-- Actions -->
        <div class="flex justify-between pt-6 border-t border-gray-200">
          <%= link_to "Cancel", recruiter_jobs_path, 
              class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
          
          <div class="flex space-x-3">
            <%= f.submit "Save as Draft", name: "draft", 
                class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
            <%= f.submit "Publish Job", name: "publish", value: "Submit",
                class: "px-6 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>