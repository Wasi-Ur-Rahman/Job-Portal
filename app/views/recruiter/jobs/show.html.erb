<section class="section-card mb-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <span class="badge-pill <%= @job.status == "published" ? "badge-emerald" : @job.status == "closed" ? "badge-red" : "badge-slate" %>"><%= @job.status.humanize %></span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @job.title %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @job.location %> • <%= @job.employment_type.humanize %></p>
      <% if @job.salary_range.present? %>
        <p class="mt-2 text-sm font-semibold text-slate-600"><%= @job.salary_range %></p>
      <% end %>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit", edit_recruiter_job_path(@job), class: "btn-secondary" %>
      <%= button_to (@job.status == "published" ? "Close job" : "Publish job"), toggle_status_recruiter_job_path(@job), method: :patch, class: @job.status == "published" ? "btn-danger" : "btn-success" %>
      <%= button_to "Delete", recruiter_job_path(@job), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn-secondary" %>
    </div>
  </div>

  <% if @job.skills.any? %>
    <div class="mt-6 flex flex-wrap gap-2">
      <% @job.skills.each do |skill| %>
        <span class="badge-pill badge-blue"><%= skill.name %></span>
      <% end %>
    </div>
  <% end %>
</section>

<section class="mb-8 section-card">
  <h2 class="text-2xl font-bold text-slate-900">Description</h2>
  <div class="prose mt-5 max-w-none">
    <%= simple_format(@job.description) %>
  </div>
</section>

<section class="mb-8 stat-grid">
  <% @application_stats.each do |status, count| %>
    <div class="stat-card">
      <p class="stat-label"><%= status.to_s.humanize %></p>
      <p class="stat-value"><%= count %></p>
      <p class="stat-meta">Applications in this state.</p>
    </div>
  <% end %>
</section>

<section class="ui-table-wrap">
  <div class="mb-4 flex items-center justify-between px-6 pt-6">
    <div>
      <h2 class="text-2xl font-bold text-slate-900">Applications</h2>
      <p class="mt-1 text-sm text-slate-500">Candidate activity tied to this role.</p>
    </div>
  </div>

  <% if @applications.any? %>
    <div class="ui-table-scroll">
      <table class="ui-table">
        <thead>
          <tr>
            <th>Applicant</th>
            <th>Email</th>
            <th>Status</th>
            <th>Applied</th>
          </tr>
        </thead>
        <tbody>
          <% @applications.each do |application| %>
            <tr>
              <td class="font-semibold text-slate-900"><%= application.user.full_name %></td>
              <td class="text-slate-500"><%= application.user.email %></td>
              <td><span class="badge-pill badge-blue"><%= application.status.humanize %></span></td>
              <td class="text-slate-500"><%= application.applied_at.strftime("%B %d, %Y %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="px-6 pb-6 pt-4">
      <%= paginate @applications %>
    </div>
  <% else %>
    <div class="ui-empty-state m-6">
      <p>No applications yet for this role.</p>
    </div>
  <% end %>
</section>
