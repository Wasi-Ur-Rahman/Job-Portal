<div class="px-4 py-6 sm:px-0">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Team Management</h1>
    <p class="mt-2 text-gray-600">Manage recruiters for <%= @company.name %></p>
  </div>

  <!-- Pending Requests -->
  <% if @pending_requests.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-8">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg font-medium text-gray-900">
          Pending Requests (<%= @pending_requests.count %>)
        </h3>
      </div>
      <ul class="divide-y divide-gray-200">
        <% @pending_requests.each do |request| %>
          <li class="px-4 py-4">
            <div class="flex items-center justify-between">
              <div>
                <h4 class="text-sm font-medium text-gray-900"><%= request.user.full_name %></h4>
                <p class="text-sm text-gray-500"><%= request.user.email %></p>
                <p class="text-sm text-gray-600">
                  <strong>Title:</strong> <%= request.title %><br>
                  <strong>Message:</strong> <%= truncate(request.contact_info['message'], length: 100) %>
                </p>
              </div>
              <div class="flex space-x-2">
                <%= button_to "Approve", approve_request_recruiter_team_path(request), method: :patch,
                    class: "px-3 py-2 text-sm font-medium text-white bg-green-600 rounded hover:bg-green-700" %>
                <%= button_to "Reject", reject_request_recruiter_team_path(request), method: :patch,
                    class: "px-3 py-2 text-sm font-medium text-white bg-red-600 rounded hover:bg-red-700" %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Current Team -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium text-gray-900">
        Current Team (<%= @current_recruiters.count %>)
      </h3>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @current_recruiters.each do |membership| %>
        <li class="px-4 py-4">
          <div class="flex items-center justify-between">
            <div>
              <h4 class="text-sm font-medium text-gray-900"><%= membership.user.full_name %></h4>
              <p class="text-sm text-gray-500"><%= membership.user.email %></p>
              <p class="text-sm text-gray-600">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                           <%= membership.manager? ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>">
                  <%= membership.role.humanize %>
                </span>
                <% if membership.is_primary %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gold-100 text-gold-800">
                    Primary
                  </span>
                <% end %>
              </p>
            </div>
            <div>
              <% unless membership.user == current_user || membership.is_primary %>
                <%= button_to "Remove", remove_recruiter_recruiter_team_path(membership), method: :delete,
                    class: "px-3 py-2 text-sm font-medium text-red-600 hover:text-red-700",
                    confirm: "Are you sure you want to remove #{membership.user.full_name} from the team?" %>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div>