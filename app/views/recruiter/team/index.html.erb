<section class="page-hero relative">
  <span class="page-kicker">Team management</span>
  <h1 class="page-title">Manage who can hire on behalf of <%= @company.name %>.</h1>
  <p class="page-subtitle">Review incoming access requests and keep the active recruiter roster clean.</p>
</section>

<% if @pending_requests.any? %>
  <section class="section-card mb-8">
    <h2 class="text-2xl font-bold text-slate-900">Pending requests</h2>
    <div class="mt-5 space-y-4">
      <% @pending_requests.each do |request| %>
        <div class="section-card-muted">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
              <h3 class="text-lg font-bold text-slate-900"><%= request.user.full_name %></h3>
              <p class="mt-1 text-sm text-slate-500"><%= request.user.email %></p>
              <p class="mt-3 text-sm text-slate-600"><strong>Title:</strong> <%= request.title %></p>
              <p class="mt-2 text-sm text-slate-600"><strong>Message:</strong> <%= truncate(request.contact_info["message"], length: 120) %></p>
            </div>
            <div class="flex flex-wrap gap-2">
              <%= button_to "Approve", approve_request_recruiter_team_path(request), method: :patch, class: "btn-success" %>
              <%= button_to "Reject", reject_request_recruiter_team_path(request), method: :patch, class: "btn-danger" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<section class="section-card">
  <h2 class="text-2xl font-bold text-slate-900">Current team</h2>
  <div class="mt-5 space-y-4">
    <% @current_recruiters.each do |membership| %>
      <div class="section-card-muted">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="text-lg font-bold text-slate-900"><%= membership.user.full_name %></h3>
              <span class="badge-pill <%= membership.manager? ? "badge-violet" : "badge-blue" %>"><%= membership.role.humanize %></span>
              <% if membership.is_primary %>
                <span class="badge-pill badge-amber">Primary</span>
              <% end %>
            </div>
            <p class="mt-2 text-sm text-slate-500"><%= membership.user.email %></p>
          </div>

          <% unless membership.user == current_user || membership.is_primary %>
            <%= button_to "Remove", remove_recruiter_recruiter_team_path(membership), method: :delete, class: "btn-secondary", data: { confirm: "Are you sure you want to remove #{membership.user.full_name} from the team?" } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
