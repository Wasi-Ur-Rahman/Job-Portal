<div class="max-w-4xl mx-auto py-8">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Welcome, Recruiter!</h1>
    <p class="mt-2 text-gray-600">Choose how you'd like to get started</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Create Company -->
    <div class="bg-white p-6 rounded-lg border-2 border-gray-200 hover:border-indigo-300">
      <div class="text-center">
        <div class="mx-auto h-12 w-12 bg-indigo-100 rounded-full flex items-center justify-center mb-4">
          <svg class="h-6 w-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Create New Company</h3>
        <p class="text-gray-600 mb-4">Register your company and become a manager</p>
        <%= link_to "Create Company", new_company_path,
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
      </div>
    </div>

    <!-- Join Company -->
    <div class="bg-white p-6 rounded-lg border-2 border-gray-200 hover:border-indigo-300">
      <div class="text-center">
        <div class="mx-auto h-12 w-12 bg-green-100 rounded-full flex items-center justify-center mb-4">
          <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Join Existing Company</h3>
        <p class="text-gray-600 mb-4">Request to join an existing company as a recruiter</p>
        
        <!-- Company selection -->
        <%= form_with url: join_company_recruiter_onboarding_path, method: :get, local: true do |f| %>
          <%= f.select :company_id, options_from_collection_for_select(@companies, :id, :name),
              { prompt: 'Select Company' },
              { class: "block w-full mb-3 border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" } %>
          <%= f.submit "Continue", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700" %>
        <% end %>
      </div>
    </div>
  </div>
</div>