<section class="page-hero relative">
  <span class="page-kicker">Recruiter onboarding</span>
  <h1 class="page-title">Choose the fastest path into the hiring workspace.</h1>
  <p class="page-subtitle">Start a new company profile or request access to an existing team with clearer guidance on what happens next.</p>
</section>

<section class="grid gap-6 md:grid-cols-2">
  <article class="section-card">
    <span class="badge-pill badge-teal">Option 1</span>
    <h2 class="mt-4 text-2xl font-bold text-slate-900">Create a new company</h2>
    <p class="mt-3 text-sm leading-7 text-slate-600">Best when you’re the first recruiter or manager representing the organization on the platform.</p>
    <div class="mt-6">
      <%= link_to "Register company", new_company_path, class: "btn-primary" %>
    </div>
  </article>

  <article class="section-card">
    <span class="badge-pill badge-emerald">Option 2</span>
    <h2 class="mt-4 text-2xl font-bold text-slate-900">Join an existing company</h2>
    <p class="mt-3 text-sm leading-7 text-slate-600">Request recruiter access from an existing hiring team and let managers review your role and experience.</p>

    <%= form_with url: join_company_recruiter_onboarding_path, method: :get, local: true, class: "mt-6 space-y-4" do |f| %>
      <div>
        <%= f.label :company_id, "Choose company", class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= f.select :company_id, options_from_collection_for_select(@companies, :id, :name), { prompt: "Select company" } %>
      </div>
      <%= f.submit "Continue", class: "btn-primary" %>
    <% end %>
  </article>
</section>
