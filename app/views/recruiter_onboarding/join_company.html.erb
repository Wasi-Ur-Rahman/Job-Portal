<section class="page-hero relative">
  <span class="page-kicker">Join team</span>
  <h1 class="page-title">Request recruiter access to <%= @company.name %>.</h1>
  <p class="page-subtitle">Make the request easier to review by giving managers a precise role, relevant experience, and a short motivation note.</p>
</section>

<div class="grid gap-8 lg:grid-cols-[minmax(0,1.4fr)_320px]">
  <section class="section-card">
    <%= form_with url: recruiter_onboarding_submit_request_path, method: :post, local: true, class: "space-y-6" do |f| %>
      <%= hidden_field_tag :company_id, @company.id %>

      <div>
        <%= label_tag :title, "Your title", class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= text_field_tag :title, nil, required: true, placeholder: "Senior Recruiter, Talent Partner, Hiring Manager" %>
      </div>

      <div>
        <%= label_tag :experience, "Recruiting experience", class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= text_field_tag :experience, nil, placeholder: "5 years in technical hiring" %>
      </div>

      <div>
        <%= label_tag :message, "Why do you want to join this company?", class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= text_area_tag :message, nil, rows: 7, required: true, placeholder: "Explain your fit, context, and why managers should trust this request." %>
      </div>

      <div class="flex flex-col gap-3 border-t border-slate-200 pt-5 sm:flex-row sm:justify-between">
        <%= link_to "Back", recruiter_onboarding_path, class: "btn-secondary" %>
        <%= f.submit "Submit request", class: "btn-primary" %>
      </div>
    <% end %>
  </section>

  <aside class="section-card-muted h-fit">
    <h2 class="text-lg font-bold text-slate-900"><%= @company.name %></h2>
    <p class="mt-2 text-sm text-slate-500"><%= @company.location %> • <%= @company.industry %> • <%= @company.size %> employees</p>
    <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-600">
      <li>Managers review your profile and your message.</li>
      <li>You’ll be notified when they approve or reject the request.</li>
      <li>Approved recruiters can manage jobs and applications immediately.</li>
    </ul>
  </aside>
</div>
