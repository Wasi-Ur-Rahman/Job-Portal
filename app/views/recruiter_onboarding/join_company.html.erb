<div class="max-w-3xl mx-auto py-8">
  <div class="mb-6">
    <%= link_to recruiter_onboarding_path, class: "text-indigo-600 hover:text-indigo-900" do %>
      ← Back to Options
    <% end %>
  </div>

  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Request to Join <%= @company.name %></h1>
        <p class="mt-2 text-gray-600">Fill out this form to request recruiter access to this company</p>
      </div>

      <!-- Company Info -->
      <div class="bg-gray-50 rounded-lg p-4 mb-6">
        <div class="flex items-center">
          <% if @company.logo.attached? %>
            <%= image_tag @company.logo, class: "h-16 w-16 rounded-lg object-cover mr-4" %>
          <% else %>
            <div class="h-16 w-16 bg-gray-200 rounded-lg flex items-center justify-center mr-4">
              <span class="text-lg font-medium text-gray-600"><%= @company.name.first.upcase %></span>
            </div>
          <% end %>
          
          <div>
            <h3 class="text-lg font-medium text-gray-900"><%= @company.name %></h3>
            <p class="text-sm text-gray-500">
              <%= @company.location %> • <%= @company.industry %> • <%= @company.size %> employees
            </p>
          </div>
        </div>
      </div>

      <%= form_with url: recruiter_onboarding_submit_request_path, method: :post, local: true, class: "space-y-6" do |f| %>
        <%= hidden_field_tag :company_id, @company.id %>

        <div>
          <%= label_tag :title, "Your Job Title", class: "block text-sm font-medium text-gray-700" %>
          <%= text_field_tag :title, nil, required: true,
              class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
              placeholder: "e.g. Senior Recruiter, Talent Acquisition Specialist" %>
        </div>

        <div>
          <%= label_tag :experience, "Years of Recruiting Experience", class: "block text-sm font-medium text-gray-700" %>
          <%= text_field_tag :experience, nil,
              class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
              placeholder: "e.g. 5 years" %>
        </div>

        <div>
          <%= label_tag :message, "Why do you want to join this company?", class: "block text-sm font-medium text-gray-700" %>
          <%= text_area_tag :message, nil, rows: 6, required: true,
              class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
              placeholder: "Tell the company managers why you'd be a great addition to their team..." %>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-md p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-blue-800">What happens next?</h3>
              <div class="mt-2 text-sm text-blue-700">
                <ul class="list-disc list-inside space-y-1">
                  <li>Your request will be sent to the company managers</li>
                  <li>They will review your profile and request</li>
                  <li>You'll be notified via email when they make a decision</li>
                  <li>If approved, you'll get full recruiter access to post jobs and manage applications</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <div class="flex justify-between pt-6 border-t border-gray-200">
          <%= link_to "Cancel", recruiter_onboarding_path, 
              class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
          
          <%= f.submit "Submit Request", 
              class: "px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>