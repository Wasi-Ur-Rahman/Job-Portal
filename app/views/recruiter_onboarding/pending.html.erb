<section class="status-panel">
  <div class="status-panel-icon">
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
  </div>

  <span class="badge-pill badge-amber">Pending</span>
  <h1 class="mt-4 text-4xl font-bold text-slate-900">Your recruiter access is waiting for approval.</h1>
  <p class="mt-3 text-sm leading-7 text-slate-600">Company managers or admins are reviewing the requests tied to your account.</p>

  <div class="mt-8 grid gap-4 text-left">
    <% @pending_companies.each do |company| %>
      <div class="section-card-muted">
        <p class="text-lg font-bold text-slate-900"><%= company.name %></p>
        <p class="mt-1 text-sm text-slate-500">Submitted <%= company.created_at.strftime("%B %d, %Y") %></p>
      </div>
    <% end %>

    <% @pending_memberships.each do |membership| %>
      <div class="section-card-muted">
        <p class="text-lg font-bold text-slate-900"><%= membership.company.name %></p>
        <p class="mt-1 text-sm text-slate-500">Requested <%= membership.created_at.strftime("%B %d, %Y") %></p>
      </div>
    <% end %>
  </div>

  <div class="mt-8 flex flex-wrap justify-center gap-3">
    <%= link_to "Update profile", edit_user_registration_path, class: "btn-secondary" %>
    <%= link_to "Browse jobs", jobs_path, class: "btn-primary" %>
  </div>
</section>
