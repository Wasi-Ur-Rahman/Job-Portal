<div class="max-w-3xl mx-auto py-8">
  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6 text-center">
      <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-yellow-100 mb-4">
        <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      
      <h1 class="text-2xl font-bold text-gray-900 mb-4">Request Pending</h1>
      
      <!-- Show Pending Companies -->
      <% if @pending_companies.any? %>
        <p class="text-gray-600 mb-6">Your company application is under review</p>
        
        <div class="bg-gray-50 rounded-lg p-6 mb-6">
          <% @pending_companies.each do |company| %>
            <div class="mb-4 last:mb-0">
              <h3 class="text-lg font-medium text-gray-900"><%= company.name %></h3>
              <p class="text-sm text-gray-500">Submitted <%= company.created_at.strftime('%B %d, %Y') %></p>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 mt-2">
                Pending Admin Approval
              </span>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Show Pending Membership Requests -->
      <% if @pending_memberships.any? %>
        <p class="text-gray-600 mb-6">Your recruiter request is under review</p>
        
        <div class="bg-gray-50 rounded-lg p-6 mb-6">
          <% @pending_memberships.each do |membership| %>
            <div class="mb-4 last:mb-0">
              <h3 class="text-lg font-medium text-gray-900"><%= membership.company.name %></h3>
              <p class="text-sm text-gray-500">Requested <%= membership.created_at.strftime('%B %d, %Y') %></p>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 mt-2">
                Pending Manager Approval
              </span>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="bg-blue-50 rounded-lg p-4 mb-6">
        <h3 class="text-sm font-medium text-blue-900 mb-2">What's happening?</h3>
        <ul class="text-sm text-blue-800 space-y-1 text-left max-w-md mx-auto">
          <% if @pending_companies.any? %>
            <li>• Admin is reviewing your company information</li>
            <li>• This typically takes 1-2 business days</li>
          <% end %>
          <% if @pending_memberships.any? %>
            <li>• Company managers are reviewing your request</li>
            <li>• They will contact you if they need more information</li>
          <% end %>
          <li>• You'll receive an email notification once reviewed</li>
          <li>• After approval, you can start posting jobs immediately</li>
        </ul>
      </div>

      <div class="flex justify-center space-x-4">
        <%= link_to "Update Profile", edit_user_registration_path, 
            class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
        <%= link_to "Browse Jobs", jobs_path, 
            class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
      </div>
    </div>
  </div>
</div>