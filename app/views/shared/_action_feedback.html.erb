<section class="status-panel">
  <div class="status-panel-icon">
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 13l4 4L19 7" />
    </svg>
  </div>

  <span class="badge-pill badge-teal"><%= local_assigns.fetch(:badge, "Action complete") %></span>
  <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= title %></h1>
  <p class="mt-3 text-sm leading-7 text-slate-600"><%= message %></p>

  <div class="mt-8 flex flex-wrap justify-center gap-3">
    <% if local_assigns[:primary_label] && local_assigns[:primary_path] %>
      <%= link_to primary_label, primary_path, class: "btn-primary" %>
    <% end %>
    <% if local_assigns[:secondary_label] && local_assigns[:secondary_path] %>
      <%= link_to secondary_label, secondary_path, class: "btn-secondary" %>
    <% end %>
  </div>
</section>
