<section class="section-card max-w-5xl mx-auto">
  <%= form_with(model: @user, url: profile_path, method: :patch, local: true, html: { multipart: true, class: "space-y-8" }) do |f| %>
    <% if @user.errors.any? %>
      <div class="flash-banner alert">
        <div>
          <p class="font-semibold">Please review these fields</p>
          <ul class="mt-2 list-disc pl-5">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="grid gap-8 lg:grid-cols-2">
      <div class="section-card-muted space-y-5">
        <h2 class="text-xl font-bold text-slate-900">Personal details</h2>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :first_name, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= f.text_field :first_name %>
          </div>
          <div>
            <%= f.label :last_name, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= f.text_field :last_name %>
          </div>
        </div>

        <div>
          <%= f.label :username, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.text_field :username %>
        </div>

        <div>
          <%= f.label :location, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.text_field :location %>
        </div>

        <div>
          <%= f.label :bio, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= f.text_area :bio, rows: 6 %>
        </div>
      </div>

      <div class="space-y-8">
        <div class="section-card-muted" data-controller="tags" data-tags-param-name-value="user[skills_list][]">
          <h2 class="text-xl font-bold text-slate-900">Skills</h2>
          <p class="mt-2 text-sm text-slate-500">Add the tools, languages, and domains you want matched against.</p>

          <div data-tags-target="tagsContainer" class="mt-4 flex flex-wrap gap-2">
            <% @user.skills.each do |skill| %>
              <span class="inline-flex items-center gap-2 rounded-full bg-teal-50 px-3 py-1 text-sm font-semibold text-teal-700">
                <%= skill.name %>
                <button type="button" data-action="tags#removeTag" class="font-bold text-teal-700">×</button>
                <input type="hidden" name="user[skills_list][]" value="<%= skill.name %>">
              </span>
            <% end %>
          </div>

          <div class="mt-4 flex gap-3">
            <input type="text" placeholder="Add a skill" data-action="keydown.enter->tags#addTag" data-tags-target="input">
            <button type="button" data-action="tags#addTag" class="btn-primary">Add</button>
          </div>
        </div>

        <div class="section-card-muted space-y-4">
          <h2 class="text-xl font-bold text-slate-900">Resume</h2>
          <%= f.file_field :resume %>
          <% if @user.resume.attached? %>
            <div class="rounded-2xl bg-white p-4 shadow-sm">
              <p class="text-sm font-semibold text-slate-800"><%= @user.resume.filename %></p>
              <div class="mt-3 flex flex-wrap gap-2">
                <%= link_to "View", rails_blob_path(@user.resume, disposition: "inline"), target: "_blank", class: "btn-secondary" %>
                <%= link_to "Download", rails_blob_path(@user.resume, disposition: "attachment"), class: "btn-ghost" %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="section-card-muted space-y-4">
          <h2 class="text-xl font-bold text-slate-900">Password</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <%= f.label :password, "New password", class: "mb-2 block text-sm font-semibold text-slate-700" %>
              <%= f.password_field :password, autocomplete: "new-password", placeholder: "Leave blank to keep current" %>
            </div>
            <div>
              <%= f.label :password_confirmation, "Confirm password", class: "mb-2 block text-sm font-semibold text-slate-700" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Repeat new password" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="flex justify-end">
      <%= f.submit "Save profile", class: "btn-primary" %>
    </div>
  <% end %>
</section>
