<section class="section-card mb-8">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <span class="badge-pill badge-teal">Profile</span>
      <h1 class="mt-4 text-4xl font-bold text-slate-900"><%= @user.first_name %> <%= @user.last_name %></h1>
      <p class="mt-2 text-lg text-slate-500"><%= @user.email %></p>
      <% if @user.location.present? %>
        <p class="mt-2 text-sm font-semibold text-slate-600"><%= @user.location %></p>
      <% end %>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit profile", profile_edit_path, class: "btn-primary" %>
      <%= link_to "Bookmarks", bookmarks_path, class: "btn-secondary" %>
      <%= link_to "Applications", applications_path, class: "btn-secondary" %>
    </div>
  </div>
</section>

<div class="grid gap-8 lg:grid-cols-[minmax(0,1.5fr)_360px]">
  <section class="section-card">
    <h2 class="text-2xl font-bold text-slate-900">About you</h2>
    <dl class="mt-6 grid gap-5 md:grid-cols-2">
      <div class="section-card-muted">
        <dt class="text-xs uppercase tracking-[0.18em] text-slate-400">First name</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-900"><%= @user.first_name %></dd>
      </div>
      <div class="section-card-muted">
        <dt class="text-xs uppercase tracking-[0.18em] text-slate-400">Last name</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-900"><%= @user.last_name %></dd>
      </div>
      <div class="section-card-muted md:col-span-2">
        <dt class="text-xs uppercase tracking-[0.18em] text-slate-400">Bio</dt>
        <dd class="mt-2 text-sm leading-7 text-slate-600"><%= @user.bio.presence || "Add a short bio to help recruiters understand your focus." %></dd>
      </div>
    </dl>

    <% if @user.skills.any? %>
      <div class="mt-8">
        <h3 class="text-lg font-bold text-slate-900">Skills</h3>
        <div class="mt-4 flex flex-wrap gap-2">
          <% @user.skills.each do |skill| %>
            <span class="badge-pill badge-blue"><%= skill.name %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <aside class="section-card-muted h-fit">
    <h2 class="text-lg font-bold text-slate-900">Documents</h2>
    <% if @user.resume.attached? %>
      <div class="mt-4 rounded-2xl bg-white p-4 shadow-sm">
        <p class="text-sm font-semibold text-slate-800"><%= @user.resume.filename %></p>
        <div class="mt-4 flex flex-wrap gap-2">
          <%= link_to "View", rails_blob_path(@user.resume, disposition: "inline"), target: "_blank", class: "btn-secondary" %>
          <%= link_to "Download", rails_blob_path(@user.resume, disposition: "attachment"), class: "btn-primary" %>
        </div>
      </div>
    <% else %>
      <p class="mt-3 text-sm text-slate-500">No resume uploaded yet.</p>
    <% end %>
  </aside>
</div>
