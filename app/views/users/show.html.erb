<div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-lg overflow-hidden">
  <!-- Header -->
  <div class="bg-indigo-600 p-6">
    <h1 class="text-3xl font-bold text-white"><%= @user.first_name %> <%= @user.last_name %></h1>
    <p class="text-indigo-200 mt-1"><%= @user.email %></p>
    <% if @user.location.present? %>
      <p class="text-indigo-200 mt-1"><%= @user.location %></p>
    <% end %>
  </div>

  <!-- Body -->
  <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Left: Personal Info -->
    <div class="space-y-4">
      <h2 class="text-xl font-semibold text-gray-700">Personal Info</h2>
      <p><span class="font-medium">First Name:</span> <%= @user.first_name %></p>
      <p><span class="font-medium">Last Name:</span> <%= @user.last_name %></p>
      <p><span class="font-medium">Email:</span> <%= @user.email %></p>
      <% if @user.bio.present? %>
        <p><span class="font-medium">Bio:</span> <%= @user.bio %></p>
      <% end %>
      <% if @user.skills.any? %>
        <div>
          <span class="font-medium">Skills:</span>
          <div class="flex flex-wrap gap-2 mt-1">
            <% @user.skills.each do |skill| %>
              <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-sm"><%= skill.name %></span>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if @user.resume.attached? %>
        <p>
          <span class="font-medium">Resume:</span>
          <%= link_to "View", rails_blob_path(@user.resume, disposition: "inline"), target: "_blank", class: "text-indigo-600 hover:underline" %> |
          <%= link_to "Download", rails_blob_path(@user.resume, disposition: "attachment"), class: "text-indigo-600 hover:underline" %>
        </p>
      <% end %>
    </div>

    <!-- Right: Quick Links -->
    <div class="space-y-4">
      <h2 class="text-xl font-semibold text-gray-700">Quick Links</h2>
      <%= link_to "Edit Profile", profile_edit_path, class: "block px-4 py-2 rounded-lg bg-indigo-100 text-indigo-700 hover:bg-indigo-200 transition" %>
      <%= link_to "Bookmarks", bookmarks_path, class: "block px-4 py-2 rounded-lg bg-indigo-100 text-indigo-700 hover:bg-indigo-200 transition" %>
      <%= link_to "Applications", applications_path, class: "block px-4 py-2 rounded-lg bg-indigo-100 text-indigo-700 hover:bg-indigo-200 transition" %>
    </div>
  </div>
</div>
